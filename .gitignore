# Ignore configuration files that may contain sensitive information.
sites/*/settings*.php
sites/*/settings.local.php
# Ignore paths that contain user-generated content.
sites/*/files
sites/*/private

sites/*/files/styles/
sites/*/files/css/
sites/*/files/js/

# IDE/editor files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

*.log
*.tmp
*.cache
*.pid
