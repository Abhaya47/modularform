    'primary key' => ['r_id'],
    'indexes' => [
      'q_id'    => ['q_id'],
      'form_id' => ['form_id'],
    ],
  ];

  $schema['modularform_question_options'] = array(
    'description' => t('Question options'),
    'fields' => array(
      'o_id' => [
        'description' => t('Unique option key (opt_{fid}_{uniqid})'),
