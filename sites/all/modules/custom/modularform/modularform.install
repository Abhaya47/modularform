<?php

/**
 * Implements hook_schema()
 */
function modularform_schema()
{
  $schema = array();

  $schema['modularform_forms'] = array(
    'description' => t('Forms'),
    'fields' => array(
      'id' => array(
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'title' => array(
        'description' => t('Title of the Form'),
        'type' => 'varchar',
        'length' => 100,
      ),
      'description' => array(
        'description' => t('Description of the Form'),
        'type' => 'text',
        'size' => 'big',
      ),
      'status' => array(
        'description' => t('Status of the Form 0 is drafted, 1 is published'),
        'type' => 'int',
        'size' => 'tiny',
        'default' => 1,
      ),
      'slug' => array(
        'description' => t('Slug of the Form'),
        'type' => 'varchar',
        'length' => 255,
      ),
      'closes' => array(
        'description' => t('Whether form closes after a certain time or at a date'),
        'type' => 'int',
        'size' => 'tiny',
        'default' => 0,
      ),
      'closes_at' => array(
        'description' => t('Form unavailable after'),
        'type' => 'int',
        'default' => 0
      ),
      'created_by' => array(
        'description' => t('Creator of the Form using drupal user id'),
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'created_at' => array(
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0
      ),
      'updated_at' => array(
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0
      ),
    ),
    'primary key' => array('id'),
    'indexes' => array(
      'status'=>array('status'),
      'title' => array('title'),
    ),
  );

  $schema['modularform_sections'] = array(
    'description' => t('Sections'),
    'fields' => array(
//      'id' => array(
//        'type' => 'serial',
//        'unsigned' => TRUE,
//        'not null' => TRUE,
//      ),
      'sec_id' => [
        'description' => t('Unique section key (sec_{fid}_{uniqid})'),
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
      ],
      'form_id' => array(
        'description' => t('Form foreign key'),
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'name' => array(
        'description' => t('Name of the section'),
        'type' => 'varchar',
        'length' => 100,
      ),
      'weight' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'created_at' => array(
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0
      ),
      'updated_at' => array(
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0
      ),
    ),
    'primary key' => array('sec_id'),
    'indexes' => array(
      'form_id' => array('form_id'),
    ),
  );

  $schema['modularform_questions'] = array(
    'description' => t('Questions'),
    'fields' => array(
//      'id' => array(
//        'type' => 'serial',
//        'unsigned' => TRUE,
//        'not null' => TRUE,
//      ),
      'q_id' => [
        'description' => t('Unique question key (q_{fid}_{uniqid})'),
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
      ],
      'form_id' => array(
        'description' => t('Form foreign key'),
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'sec_id' => array(
        'description' => t('Section foreign key'),
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
      ),
      'label' => array(
        'description' => t('Label'),
        'type' => 'varchar',
        'length' => 100,
      ),
      'description' => array(
        'description' => t('Description'),
        'type' => 'text',
