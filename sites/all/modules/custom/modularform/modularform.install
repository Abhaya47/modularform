        'default' => 0
      ),
      'updated_at' => array(
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0
      ),
    ),
    'primary key' => array('o_id'),
    'indexes' => array(
      'question_id' => array('q_id'),
      'form_id' => ['form_id'],
    )
  );

  $schema['modularform_responses'] = array(
    'description' => t('Responses'),
    'fields' => array(
      'id' => array(
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'form_id' => array(
        'description' => t('Form foreign key'),
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'user_id' => array(
