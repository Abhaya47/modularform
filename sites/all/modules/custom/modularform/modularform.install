  $schema['modularform_validation_rules'] = [
    'description' => t('Validation rules per question'),
    'fields' => [
      'r_id' => [
        'description' => t('Unique rule key (r_{fid}_{uniqid})'),
        'type'        => 'varchar',
        'length'      => 64,
