        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'q_id' => [
        'description' => t('Question FK (varchar natural key)'),
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
      ],
      'created_at' => array(
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0
      ),
      'updated_at' => array(
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0
      ),
    ),
    'primary key' => array('id'),
    'indexes' => array(
      'response_id' => array('response_id'),
      'q_id'        => ['q_id'],
