      ],
      'q_id' => [
        'description' => t('Question FK'),
        'type'        => 'varchar',
        'length'      => 64,
        'not null'    => TRUE,
      ],
      'form_id' => [
        'description' => t('Form FK — enables bulk delete by form'),
        'type'        => 'int',
