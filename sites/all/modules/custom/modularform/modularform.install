function modularform_install() {}

function modularform_uninstall() {}

/**
 * Add token field to modularform_form_invites table.
 */
function modularform_update_7001(): void {
  $table = 'modularform_form_invites';

  // Define the new field.
  $field = [
    'type' => 'varchar',
    'description' => 'Unique token for identifying the form invite.',
    'length' => 64,
    'not null' => TRUE,
    'default' => '',
  ];

  // Add the field if it doesn't exist.
  if (!db_field_exists($table, 'token')) {
    db_add_field($table, 'token', $field);
  }
}

/**
 * Add status and token fields to modularform_form_members.
 */
function modularform_update_7002(): void {
  $table = 'modularform_form_members';

  // Add status field
  if (!db_field_exists($table, 'status')) {
    db_add_field($table, 'status', [
      'description' => t('Status of their response 0 for not submitted, 1 for submitted'),
      'type' => 'int',
      'size' => 'tiny',
      'unsigned' => TRUE,
      'not null' => TRUE,
      'default' => 0,
    ]);
  }

  // Add token field
  if (!db_field_exists($table, 'token')) {
    db_add_field($table, 'token', [
      'description' => t('Unique form Token'),
      'type' => 'varchar',
      'length' => 60,
      'not null' => TRUE,
      'default' => '', // required for existing rows
    ]);
  }
}

function modularform_update_7003(): void {
  $table = 'modularform_forms';

  // Add status field
  if (!db_field_exists($table, 'visibility')) {
    db_add_field($table, 'visibility', [
      'description' => t('Visibility of the Form 0 is public, 1 is restricted, 2 is private'),
      'type' => 'int',
      'size' => 'tiny',
      'not null' => TRUE,
      'default' => 0,
    ]);
  }
}

