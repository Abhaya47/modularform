    'description' => 'Stores file attachments for form answers.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'answer_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'fid' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'created_at' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'answer_id' => ['answer_id'],
      'fid' => ['fid'],
    ],
  ];

  db_create_table('modularform_answer_files', $schema);
}

function modularform_update_7013() {
  $table = 'modularform_form_members';

  if (!db_field_exists($table, 'roles')) {
    db_add_field($table, 'roles', [
      'description' => t('Role 0 for creator, 1 for viewer, 2 for participant'),
      'type' => 'int',
      'size' => 'tiny',
      'unsigned' => TRUE,
      'not null' => TRUE,
      'default' => 2,
    ]);
  }
}
