/**
 * Add unique composite keys for form_id/email
 * on modularform_responses to prevent duplicate submissions.
 */
function modularform_update_7008() {
  if (!db_index_exists('modularform_responses', 'form_user')) {
    db_add_unique_key('modularform_responses', 'form_user', [
      'form_id',
      'user_id',
    ]);
  }

  if (!db_index_exists('modularform_responses', 'form_email')) {
    db_add_unique_key('modularform_responses', 'form_email', [
      'form_id',
      'email',
    ]);
  }
}

function modularform_update_7009() {
  if (db_index_exists('modularform_responses', 'form_user')) {
    db_drop_unique_key('modularform_responses', 'form_user');
  }
}

function modularform_update_7010() {
  db_change_field(
    'modularform_answers_multi',
    'value',
    'value',
    [
      'description' => t('Options fk'),
      'type' => 'varchar',
      'length' => 64,
      'not null' => TRUE,
    ]
  );
}

function modularform_update_7011() {
  $table = 'modularform_questions';

  if (!db_field_exists($table, 'is_filterable')) {
