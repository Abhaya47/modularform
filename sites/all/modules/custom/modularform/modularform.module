function form_view_page() {
  global $user;
  if (isset($user->roles) && in_array('administrator', $user->roles)) {
    return TRUE;
  }
  if (isset($user->roles) && in_array('admin', $user->roles)) {
    return TRUE;
  }
  return FALSE;
}

function form_create_access() {
  global $user;
  if (isset($user->roles) && in_array('administrator', $user->roles)) {
    return TRUE;
  }
  if (isset($user->roles) && in_array('admin', $user->roles)) {
    return TRUE;
  }
  return FALSE;
}

function modularform_fill_access($fid) {
  $form = db_select('modularform_forms', 'f')
    ->fields('f', ['id', 'visibility'])
    ->execute()
    ->fetchAssoc();

  if ($form['visibility'] == 0) {
    return TRUE;
  }

  if ($form) {
    $token = isset($_GET['token']) ? check_plain($_GET['token']) : '';
  }
  if (empty($token)) {
    return FALSE;
  }

  global $user;
  $record = db_select('modularform_form_members', 'mfm')
    ->fields('mfm')
    ->condition('form_id', $fid)
    ->condition('token', $token)
    ->condition('uid', $user->uid)
    ->condition('status', 0)
    ->execute()
    ->fetchObject();

  return !empty($record);
}

