// view page


// create page


function modularform_mail($key, &$message, $params) {
  $form = $params['form'];
  $link = url('forms/' . $form->slug, ['absolute' => TRUE]);

  switch ($key) {
    case 'form_invite':
      // Non-Drupal user invited by email
      $message['subject'] = t('You have been invited to fill out: @title', ['@title' => $form->title]);
      $message['body'][] = t('You have been invited to access a form.');
      $message['body'][] = t('Click the link below to access it:');
      $message['body'][] = $link;
      break;

    case 'form_invite_user':
      // Existing Drupal user
      $message['subject'] = t('You have been given access to: @title', ['@title' => $form->title]);
      $message['body'][] = t('You have been granted access to a form. Log in and visit:');
      $message['body'][] = $link;
      break;

    case 'form_notify_role':
      $message['subject'] = t('You now have access to: @title', ['@title' => $form->title]);
      $message['body'][] = t('A form has been shared with your role. Log in and visit:');
      $message['body'][] = $link;
      break;
  }
}

/**
 * Implements hook_cron_queue_info().
 */
function modularform_cron_queue_info() {
  return [
    'modularform_mail_queue' => [
      'worker callback' => 'modularform_mail_queue_worker',
      'time' => 30, // max seconds per cron run to spend on this queue
    ],
  ];
}

function modularform_mail_queue_worker($item) {
  drupal_mail(
    'modularform',
    $item['key'],
    $item['to'],
    language_default(),
    $item['params']
  );
}

/**
 * Implements hook_theme().
 */
function modularform_theme() {
  return [
    'dashboard' => [
      'variables' => [
        'header' => NULL,
        'rows' => NULL,
      ],
      'template' => 'modularform-dashboard',
      'path' => drupal_get_path('module', 'modularform') . '/templates',
    ],
    'modularform_initial_template' => [
      'render element' => 'form',
      'template' => 'modularform-initial',
      'path' => drupal_get_path('module', 'modularform') . '/templates',
    ],
    'trash' => [
      'variables' => [
        'header' => NULL,
        'rows' => NULL,
      ],
      'template' => 'modularform-trash',
      'path' => drupal_get_path('module', 'modularform') . '/templates',
    ],
  ];
}

