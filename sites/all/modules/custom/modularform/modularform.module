      'description' => t('Allow users to edit existing forms.'),
    ],
    'delete forms' => [
      'title' => t('Delete forms'),
      'description' => t('Allow users to delete forms.'),
    ],
    'answer forms' => [
      'title' => t('Answer forms'),
      'description' => t('Allow users to answer forms.'),
    ],
    'view responses' => [
      'title' => t('View responses'),
      'description' => t('Allow users to view form responses.'),
    ],
    'edit responses' => [
      'title' => t('Edit responses'),
      'description' => t('Allow users to edit form responses.'),
    ],
    'delete responses' => [
      'title' => t('Delete responses'),
      'description' => t('Allow users to delete form responses.'),
    ],
  ];
}

// =====================
// HELPERS
// =====================

/**
 * TRUE if the current user is a site-level administrator (access to
 * everything).
 */
function _modularform_is_site_admin() {
  global $user;
  return isset($user->roles) && in_array('administrator', $user->roles);
}

/**
 * TRUE if the current user has the 'admin' role (form owner — can CRUD
 * own/member forms).
 */
function _modularform_is_form_admin() {
  global $user;
  return isset($user->roles) && in_array('admin', $user->roles);
}

/**
 * Returns the current user's membership role for a given form, or FALSE if not
 * a member. Roles: 0 = creator, 1 = viewer, 2 = participant.
 */
function _modularform_form_member_role($fid) {
  global $user;

  // Site admin has implicit creator-level access on every form.
  if (_modularform_is_site_admin()) {
    return 0;
  }

  // Check created_by first.
  $form = db_select('modularform_forms', 'f')
    ->fields('f', ['created_by'])
    ->condition('f.id', $fid)
    ->execute()
    ->fetchObject();

  if ($form && $form->created_by == $user->uid) {
    return 0;
  }

  // Fall back to modularform_form_members.
  $member = db_select('modularform_form_members', 'fm')
    ->fields('fm', ['roles'])
    ->condition('fm.form_id', $fid)
    ->condition('fm.uid', $user->uid)
    ->execute()
    ->fetchObject();

  return $member ? (int) $member->roles : FALSE;
}

// =====================
// FORM ACCESS CALLBACKS
// =====================

/**
 * Access callback: view forms list / dashboard.
 *
 * - administrator: always.
 * - admin: yes (they manage their own forms).
 * - others: requires 'view forms' permission.
 */
function form_view_access() {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (_modularform_is_form_admin()) {
    return user_access('view forms');
  }
  return user_access('view forms');  // regular users can still be granted this
}

/**
 * Access callback: create a new form.
 *
 * - administrator: always.
 * - admin: yes if they have 'create forms' permission.
 * - others: no.
 */
function form_create_access() {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (_modularform_is_form_admin()) {
    return user_access('create forms');
  }
  return FALSE;
}

/**
 * Access callback: edit/build a form.
 *
 * - administrator: always.
 * - admin: only if they are the form creator (role 0) or a member.
 * - others: no.
 *
 * @param int $fid Form ID from the URL wildcard.
 */
function form_edit_access($fid) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (_modularform_is_form_admin() && user_access('edit forms')) {
    return _modularform_form_member_role($fid) === 0; // must be creator
  }
  return FALSE;
}

/**
 * Access callback: delete / restore / trash / permanent-delete a form.
 *
 * - administrator: always.
 * - admin: only if they are the form creator (role 0).
 * - others: no.
 *
 * @param int $fid Form ID (NULL for list pages like trash).
 */
function form_delete_access($fid = NULL) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (_modularform_is_form_admin() && user_access('delete forms')) {
    if ($fid === NULL) {
      return TRUE; // trash list page — just needs the role+permission
    }
    return _modularform_form_member_role($fid) === 0; // must be creator
  }
  return FALSE;
}

/**
 * Access callback: fill / answer a form.
 *
 * - administrator: always.
 * - Public forms (visibility == 0): any user with 'answer forms' permission.
 * - Private forms: requires a valid unused invitation token.
 *
 * @param int $fid Form ID from the URL wildcard.
 */
function modularform_fill_access($fid) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!user_access('answer forms')) {
    return FALSE;
  }

  $form = db_select('modularform_forms', 'f')
    ->fields('f', ['id', 'visibility', 'status'])
    ->condition('f.id', $fid)
    ->execute()
    ->fetchObject();

  if (!$form) {
    return FALSE;
  }

  if ($form->status!=1){
    return FALSE;
  }

  // Public form — open to anyone with the permission.
  if ((int) $form->visibility === 0) {
    return TRUE;
  }

  // Private form — validate invitation token.
  $token = isset($_GET['token']) ? check_plain($_GET['token']) : '';
  if (empty($token)) {
    return FALSE;
  }

  global $user;
  $record = db_select('modularform_form_members', 'mfm')
    ->fields('mfm')
    ->condition('form_id', $fid)
    ->condition('token', $token)
    ->condition('uid', $user->uid)
    ->condition('status', 0)
    ->execute()
    ->fetchObject();

  return !empty($record);
}

// =====================
// RESPONSE ACCESS CALLBACKS
// =====================

/**
 * Access callback: list responses.
 *
 * - administrator: sees all responses.
 * - admin: sees responses for forms they created (role 0) or are a viewer on
 * (role 1).
 * - others: requires 'view responses' permission (sees only own responses —
 * filtered in page callback).
 */
function response_list_access() {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (_modularform_is_form_admin()) {
    return user_access('view responses');
  }
  return user_access('view responses');
}

/**
 * Access callback: view a single response.
 *
 * - administrator: always.
 * - admin (role 0 creator or role 1 viewer on the form): yes.
 * - Response owner: yes.
 * - Anonymous response / someone else's response: no.
 *
 * @param int $id Response ID from the URL wildcard.
 */
function response_view_access($id) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!user_access('view responses')) {
    return FALSE;
  }

  $response = db_select('modularform_responses', 'r')
    ->fields('r', ['form_id', 'user_id'])
    ->condition('r.id', $id)
    ->execute()
    ->fetchObject();

  if (!$response) {
    return FALSE;
  }

  // admin role: can view if they are creator (0) or viewer (1) on this form.
  if (_modularform_is_form_admin()) {
    $role = _modularform_form_member_role($response->form_id);
    if ($role !== FALSE && in_array($role, [0, 1])) {
      return TRUE;
    }
  }

  // Any user: can view their own response.
  global $user;
  if ($response->user_id == 0 || $response->user_id != $user->uid) {
    return FALSE;
  }

  return TRUE;
}

/**
 * Access callback: edit a response.
 *
 * - administrator: always.
 * - admin (role 0 creator on the form): yes.
 * - Response owner (non-anonymous): yes.
 *
 * @param int $id Response ID from the URL wildcard.
 */
function response_edit_access($id) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!user_access('edit responses')) {
    return FALSE;
  }

  $response = db_select('modularform_responses', 'r')
    ->fields('r', ['form_id', 'user_id'])
    ->condition('r.id', $id)
    ->execute()
    ->fetchObject();

  if (!$response) {
    return FALSE;
  }

  // admin role: only the form creator can edit responses.
  if (_modularform_is_form_admin()) {
    if (_modularform_form_member_role($response->form_id) === 0) {
      return TRUE;
    }
  }

  // Any user: can edit their own non-anonymous response.
  global $user;
  if ($response->user_id == 0 || $response->user_id != $user->uid) {
    return FALSE;
  }

  return TRUE;
}

/**
 * Access callback: delete a response.
 *
 * - administrator: always.
 * - admin (role 0 creator on the form): yes.
 * - Response owner (non-anonymous): yes.
 *
 * @param int $id Response ID from the URL wildcard.
 */
function response_delete_access($id) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!user_access('delete responses')) {
    return FALSE;
  }

  $response = db_select('modularform_responses', 'r')
    ->fields('r', ['form_id', 'user_id'])
    ->condition('r.id', $id)
    ->execute()
    ->fetchObject();

  if (!$response) {
    return FALSE;
  }

  // Form creator (role 0) can delete any response on their form —
  // applies to both 'admin' role users and regular users who created a form.
  if (_modularform_form_member_role($response->form_id) === 0) {
    return TRUE;
  }

  // Any user: can delete their own non-anonymous response.
  global $user;
  if ($response->user_id == 0 || $response->user_id != $user->uid) {
    return FALSE;
  }

  return TRUE;
}

