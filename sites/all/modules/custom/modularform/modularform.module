}

function modularform_menu() {
  $items = [];

  $items['forms/manage'] = [
    'title' => 'Dashboard',
    'page callback' => 'form_dashboard_page',
    'access arguments' => ['view forms'],
    // here for hook_permission. Uses the permission
    'access callback' => 'form_view_page',
    'menu_name' => 'main-menu',
  ];

  $items['forms/create'] = [
    'title' => 'Create Form',
    'page callback' => 'drupal_get_form',
    'page arguments' => ['modularform_create_form'],
    'access arguments' => ['create content'],
    'access callback' => 'form_create_access',
  ];

  $items['forms/edit/%'] = [
    'title' => 'Edit Form',
    'page callback' => 'drupal_get_form',
    'page arguments' => ['modularform_create_form', 2],
    'access arguments' => ['edit forms'],
  ];

  $items['forms/delete/%'] = [
    'title' => 'Delete Form',
    'page callback' => 'modularform_soft_delete',
    'page arguments' => [2],
    'access arguments' => ['delete forms'],
  ];

  $items['forms/permanent_delete/%'] = [
    'title' => 'Delete Form Permanently',
    'page callback' => 'modularform_perma_delete',
    'page arguments' => [2],
    'access arguments' => ['delete forms'],
  ];

  $items['forms/trash'] = [
    'title' => 'Trash',
    'page callback' => 'form_deleted_dashboard_page',
    'access arguments' => ['delete forms'],
    'menu_name' => 'main-menu',

  ];

  $items['forms/restore/%'] = [
    'title' => 'Restore Form',
    'page callback' => 'modularform_restore',
    'page arguments' => [2],
    'access arguments' => ['delete forms'],
  ];

  $items['forms/%/builder'] = [
    'title' => 'Form Builder',
    'page callback' => 'drupal_get_form',
    'page arguments' => ['modularform_builder_form', 1],
    'access arguments' => ['access content'],
    'access callback' => 'form_create_access',
  ];

  $items['forms/%/builder/preview'] = [
    'title' => 'Preview Form',
    'page callback' => 'drupal_get_form',
    'page arguments' => ['modularform_preview_form', 1],
    'access callback' => TRUE,
