    ],
    'delete responses' => [
      'title' => t('Delete responses'),
      'description' => t('Delete submitted responses.'),
    ],
  ];
}

// =====================
// HELPERS
// =====================

/**
 * TRUE if the current user is a site-level administrator.
 * Bypasses all access checks.
 */
function _modularform_is_site_admin() {
  global $user;
  return isset($user->roles) && in_array('administrator', $user->roles);
}

/**
 * TRUE if the current user is an admin or analyst.
 * Both roles can create/edit/delete their own forms.
 * The distinction (admin can manage users, analyst cannot) is handled
 * outside this module via Drupal's own role/permission config.
 */
function _modularform_is_form_admin() {
  global $user;
  return isset($user->roles) && (
      in_array('admin', $user->roles) ||
      in_array('analyst', $user->roles)
    );
}

/**
 * Returns the current user's relationship to a form.
 *
 * Return values:
 *   'creator' — user is in modularform_forms.created_by (or is site admin)
 *   0         — co-owner in form_members (can edit/view, not delete)
 *   1         — viewer in form_members (view only)
 *   2         — participant in form_members (fill only)
 *   FALSE     — no relationship to this form
 *
 * @param int $fid Form ID.
 */
function _modularform_form_member_role($fid) {
  global $user;
  $cache = &drupal_static(__FUNCTION__, []);

  if (array_key_exists($fid, $cache)) {
    return $cache[$fid];
  }

  if (_modularform_is_site_admin()) {
    return $cache[$fid] = 'creator';
  }

  $form = _modularform_get_form($fid);
  if ($form && $form->created_by == $user->uid) {
    return $cache[$fid] = 'creator';
  }

  $member = db_select('modularform_form_members', 'fm')
    ->fields('fm', ['roles'])
    ->condition('fm.form_id', $fid)
    ->condition('fm.uid', $user->uid)
    ->execute()
    ->fetchObject();

  return $cache[$fid] = ($member ? (int) $member->roles : FALSE);
}

function _modularform_get_form($fid) {
  $cache = &drupal_static(__FUNCTION__, []);

  if (!array_key_exists($fid, $cache)) {
    $cache[$fid] = db_select('modularform_forms', 'f')
      ->fields('f', ['id', 'visibility', 'status', 'closes_at', 'created_by'])
      ->condition('f.id', $fid)
      ->execute()
      ->fetchObject() ?: NULL;
  }

  return $cache[$fid];
}

function _modularform_get_response($id) {
  $cache = &drupal_static(__FUNCTION__, []);

  if (!array_key_exists($id, $cache)) {
    $cache[$id] = db_select('modularform_responses', 'r')
      ->fields('r', ['form_id', 'user_id'])
      ->condition('r.id', $id)
      ->execute()
      ->fetchObject() ?: NULL;
  }

  return $cache[$id];
}

// =====================
// FORM ACCESS CALLBACKS
// =====================

/**
 * Access callback: forms dashboard / index listing.
 * admin, analyst: always (they manage their own forms).
 * others: requires 'list forms' permission.
 */
function form_list_access() {
  return _modularform_is_site_admin()
    || _modularform_is_form_admin()
    || user_access('list forms');
}

/**
 * Access callback: view an individual form's data.
 * admin/analyst: yes if creator or member (role 0 or 1).
 * others: requires 'view forms' + membership role 0 or 1.
 *
 * @param int $fid Form ID.
 */
function form_view_access($fid) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!user_access('view forms')) {
    return FALSE;
  }
  $role = _modularform_form_member_role($fid);
  return in_array($role, ['creator', 0, 1], TRUE);
}

/**
 * Access callback: create a new form.
 * admin/analyst: yes if they have 'create forms' permission.
 * others: no.
 */
function form_create_access() {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  return _modularform_is_form_admin() && user_access('create forms');
}

/**
 * Access callback: edit form metadata.
 * admin/analyst: yes if creator or co-owner (role 0) + 'edit forms'.
 * any other user: yes if creator or co-owner (role 0) — membership is enough.
 *
 * @param int $fid Form ID.
 */
function form_edit_access($fid) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  $role = _modularform_form_member_role($fid);
  if (!in_array($role, ['creator', 0], TRUE)) {
    return FALSE;
  }
  // admin/analyst must also hold the permission
  if (_modularform_is_form_admin()) {
    return user_access('edit forms');
  }
  // regular users: membership role is sufficient
  return TRUE;
}

/**
 * Access callback: form builder.
 * Same gate as edit but requires 'build forms' permission for admin/analyst.
 * Regular users with creator/co-owner membership: membership is sufficient.
 *
 * @param int $fid Form ID.
 */
function form_build_access($fid) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  $role = _modularform_form_member_role($fid);
  if (!in_array($role, ['creator', 0], TRUE)) {
    return FALSE;
  }
  if (_modularform_is_form_admin()) {
    return user_access('build forms');
  }
  return TRUE;
}

/**
 * Access callback: preview a form.
 * creator, co-owner (0), viewer (1) and site admin only.
 * Participants (2) and unrelated users cannot preview.
 *
 * @param int $fid Form ID.
 */
function form_preview_access($fid) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  $role = _modularform_form_member_role($fid);
  return in_array($role, ['creator', 0, 1], TRUE);
}

/**
 * Access callback: delete / restore / trash / permanent-delete.
 * Only the true form creator (created_by) can delete — not co-owners.
 * admin/analyst: yes if they are the creator + 'delete forms'.
 * others: no delete rights regardless of membership.
 *
 * @param int $fid Form ID (NULL for list pages like trash).
 */
function form_delete_access($fid = NULL) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!_modularform_is_form_admin() || !user_access('delete forms')) {
    return FALSE;
  }
  if ($fid === NULL) {
    // trash list page — just needs role + permission
    return TRUE;
  }
  // must be the true creator, not just a co-owner
  return _modularform_form_member_role($fid) === 'creator';
}

/**
 * Access callback: fill / answer a form.
 *
 * @param int $fid Form ID.
 */
/**
 * @param int $fid
 * @param string|null $token  Optional — pass when checking from a link build
 *                            context. Falls back to $_GET['token'] when NULL
 *                            (normal page-load path).
 */
function modularform_fill_access($fid, $token = NULL) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!user_access('answer forms')) {
    return FALSE;
  }
  $form = _modularform_get_form($fid);
  if (!$form) {
    return FALSE;
  }
  if ((int) $form->status !== 1) {
    return FALSE;
  }
  if (_modularform_is_closed($form)) {
    return FALSE;
  }
  if ((int) $form->visibility === 0) {
    return TRUE;
  }
  global $user;
  if ($form->created_by == $user->uid) {
    return TRUE;
  }

  // Resolve token — explicit argument takes priority over $_GET
  if ($token === NULL) {
    $token = isset($_GET['token']) ? check_plain($_GET['token']) : '';
  }
  if (empty($token)) {
    return FALSE;
  }

  $record = db_select('modularform_form_members', 'mfm')
    ->fields('mfm')
    ->condition('form_id', $fid)
    ->condition('token', $token)
    ->condition('uid', $user->uid)
    ->condition('status', 0)
    ->execute()
    ->fetchObject();

  return !empty($record);
}

/**
 * Determine whether a form is closed.
 *
 * @param object|array $form Form row from the DB.
 * @return bool
 */
function _modularform_is_closed($form) {
  $closes_at = is_array($form) ? $form['closes_at'] : $form->closes_at;
  return !empty($closes_at) && REQUEST_TIME >= (int) $closes_at;
}

// =====================
// RESPONSE ACCESS CALLBACKS
// =====================

/**
 * Access callback: list responses.
 * admin/analyst: yes (filtered to their forms in the page callback).
 * others: requires 'view responses' (filtered to own responses in page callback).
 */
function response_list_access() {
  return _modularform_is_site_admin()
    || _modularform_is_form_admin()
    || user_access('view responses');
}

/**
 * Access callback: view a single response.
 * creator (role 'creator') or viewer (role 0/1) on the form: yes.
 * response owner (non-anonymous): yes.
 *
 * @param int $id Response ID.
 */
function response_view_access($id) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!user_access('view responses')) {
    return FALSE;
  }
  $response = _modularform_get_response($id);
  if (!$response) {
    return FALSE;
  }
  $role = _modularform_form_member_role($response->form_id);
  if (in_array($role, ['creator', 0, 1], TRUE)) {
    return TRUE;
  }
  global $user;
  if ($response->user_id == 0 || $response->user_id != $user->uid) {
    return FALSE;
  }
  return TRUE;
}

/**
 * Access callback: edit a response.
 * Form creator: yes.
 * Response owner (non-anonymous): yes, if form is still open.
 *
 * @param int $id Response ID.
 */
function response_edit_access($id) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!user_access('edit responses')) {
    return FALSE;
  }
  $response = _modularform_get_response($id);
  if (!$response) {
    return FALSE;
  }
  $form = _modularform_get_form($response->form_id);
  if (!$form || (int) $form->status !== 1 || _modularform_is_closed($form)) {
    return FALSE;
  }
  if (_modularform_form_member_role($response->form_id) === 'creator') {
    return TRUE;
  }
  global $user;
  if ($response->user_id == 0 || $response->user_id != $user->uid) {
    return FALSE;
  }
  return TRUE;
}

/**
 * Access callback: delete a response.
 * Form creator: yes.
 * Response owner (non-anonymous): yes.
 *
 * @param int $id Response ID.
 */
function response_delete_access($id) {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (!user_access('delete responses')) {
    return FALSE;
  }
  $response = _modularform_get_response($id);
  if (!$response) {
    return FALSE;
  }
  if (_modularform_form_member_role($response->form_id) === 'creator') {
    return TRUE;
  }
  global $user;
  if ($response->user_id == 0 || $response->user_id != $user->uid) {
    return FALSE;
  }
  return TRUE;
}

// modularform.module
// stub — returns FALSE until analytics module enables it
function modularform_analytics_access() {
  return FALSE;
}

/**
 * Implements hook_entity_info().
 */
function modularform_entity_info() {
  $info = [];

  // 1. Form Entity
  $info['modularform_form'] = [
    'label' => t('Modular Form'),
    'base table' => 'modularform_forms', // Fixed: was 'forms'
    'entity class' => 'Entity',
    'controller class' => 'EntityAPIController',
    'fieldable' => TRUE,
    'entity keys' => [
      'id' => 'id',
      'label' => 'title',
    ],
    'bundles' => [
      'modularform_form' => [
        'label' => t('Modular Form'),
      ],
    ],
    'module' => 'modularform',
  ];

  // 5. Response Entity
  $info['modularform_response'] = [
    'label' => t('Form Response'),
    'base table' => 'modularform_responses', // Fixed: was 'responses'
    'entity class' => 'Entity',
    'controller class' => 'EntityAPIController',
    'fieldable' => TRUE,
    'entity keys' => [
      'id' => 'id',
      'label' => 'email',
    ],
    'bundles' => [
      'modularform_response' => [
        'label' => t('Form Response'),
      ],
    ],
    'module' => 'modularform',
  ];
  return $info;
}

