      ],
      'template' => 'modularform-view-page',
      'path' => drupal_get_path('module', 'modularform') . '/templates',
    ],
    'modularform_people_list' => [
      'variables' => ['people' => []],
      'template' => 'modularform-people-list',
      'path' => drupal_get_path('module', 'modularform') . '/templates',
    ],
  ];
}

function custom_landing_page() {
  return '<div id="dashboard-root"></div>'; // Drupal renders page--landing.tpl.php around this
}

// ── Queue worker (hook_cron_queue_info + processor) ───────────────────────────

/**
 * Implements hook_cron_queue_info().
 */
function modularform_cron_queue_info() {
  return [
    'modularform_mail_queue' => [
      'worker callback' => 'modularform_mail_queue_worker',
      'time' => 30,    // seconds per cron run to spend on this queue
    ],
  ];
}

/**
 * Queue worker: fires the right email based on the item key.
 */
function modularform_mail_queue_worker($item) {
  switch ($item['key']) {
    // ── Existing user: fill this form ────────────────────────────────────────
    case 'form_notify_user':
      drupal_mail(
        'modularform',
        'notify_user',
        $item['to'],
        language_default(),
        $item['params']
      );
      break;

    // ── External address: register + fill ────────────────────────────────────
    case 'form_invite_external':
      drupal_mail(
        'modularform',
        'invite_external',
        $item['to'],
        language_default(),
        $item['params']
      );
      break;

    // ── Role-based notification (existing behaviour) ──────────────────────────
    case 'form_notify_role':
      drupal_mail(
        'modularform',
        'notify_role',
        $item['to'],
        language_default(),
        $item['params']
      );
      break;
  }
}

// ── hook_mail ─────────────────────────────────────────────────────────────────

/**
 * Implements hook_mail().
 */
function modularform_mail($key, &$message, $params) {
  $form = $params['form'];

  switch ($key) {
    case 'notify_user':
      $account = $params['account'];
      $form_url = $params['form_url'];

      $message['subject'] = t('You have been invited to fill out: @title', [
        '@title' => $form->title,
      ]);
      $message['body'][] = t('Hello @name,', ['@name' => $account->name]);
      $message['body'][] = t('@title is ready for you to fill out.', [
        '@title' => $form->title,
      ]);
      $message['body'][] = t('Click the link below to get started:');
      $message['body'][] = $form_url;
      $message['body'][] = t('Thank you.');
      break;

    case 'invite_external':
      $register_url = $params['register_url'];

      $message['subject'] = t('You have been invited to fill out: @title', [
        '@title' => $form->title,
      ]);
      $message['body'][] = t('Hello,');
      $message['body'][] = t('You have been invited to fill out the form: @title.', [
        '@title' => $form->title,
      ]);
      $message['body'][] = t('To get started, please register for an account using the link below:');
      $message['body'][] = $register_url;
      $message['body'][] = t('Once registered you will have access to the form.');
      $message['body'][] = t('Thank you.');
      break;

    case 'notify_role':
      $message['subject'] = t('A new form is available: @title', [
        '@title' => $form->title,
      ]);
      $message['body'][] = t('Hello,');
      $message['body'][] = t('A new form "@title" has been published and is available for your role.', [
        '@title' => $form->title,
      ]);
      $message['body'][] = url('forms/' . $form->slug . '/fill', ['absolute' => TRUE]);
      $message['body'][] = t('Thank you.');
      break;
  }
}

function modularform_library() {
  $path = drupal_get_path('module', 'modularform');
  $select2_path = 'sites/all/libraries/select2-3.5.4';

  return [
    'select2' => [
      'title' => 'Select2',
      'version' => '3.5.4',
      'js' => [
        $select2_path . '/select2.min.js' => [],
      ],
      'css' => [
        $select2_path . '/select2.css' => [],
      ],
      'dependencies' => [['system', 'jquery']],
    ],
  ];
}

function _modularform_load_jwt() {
  static $loaded = FALSE;
  if (!$loaded) {
    $base = DRUPAL_ROOT . '/sites/all/libraries/php-jwt/src/';
    require_once $base . 'JWT.php';
    require_once $base . 'Key.php';
    require_once $base . 'SignatureInvalidException.php';
    require_once $base . 'BeforeValidException.php';
    require_once $base . 'ExpiredException.php';
    $loaded = TRUE;
  }
}

/**
 * Implements hook_entity_insert().
 */
function modularform_entity_insert($entity, $type) {
  // Handle form entity
  if ($type === 'modularform_form') {
    if (module_exists('modularform_search')) {
      modularform_search_solr_sync($entity, $type);
    }
  }

  // Handle response entity
  if ($type === 'modularform_response') {
    if (module_exists('modularform_search')) {
      modularform_search_solr_sync($entity, $type);
    }
  }
}

/**
 * Implements hook_entity_update().
 */
function modularform_entity_update($entity, $type) {
  if ($type === 'modularform_form') {
    if (module_exists('modularform_search')) {
      modularform_search_solr_sync($entity, $type);
    }

    // Fire notifications only when status transitions to published
    if ((int) $entity->status === 1 && (int) $entity->original->status !== 1) {
      $now = (new DateTime('now', new DateTimeZone('UTC')))->getTimestamp();

      // Restricted members (notified = 0 only)
      $rows = db_select('modularform_form_members', 'm')
        ->fields('m', ['uid', 'token'])
        ->condition('m.form_id', $entity->id)
        ->condition('m.roles', 2)
        ->condition('m.notified', 0)
        ->execute()
        ->fetchAll(PDO::FETCH_ASSOC);

      if (!empty($rows)) {
        _modularform_queue_restricted_notifications($entity->id, $entity, $rows);

        db_update('modularform_form_members')
          ->fields(['notified' => 1, 'updated_at' => $now])
          ->condition('form_id', $entity->id)
          ->condition('uid', array_column($rows, 'uid'), 'IN')
          ->execute();
      }

      // Private members + invites (notified = 0 only)
      _modularform_queue_private_notifications($entity->id, $entity, $now);
    }
  }

  if ($type === 'modularform_response') {
    if (module_exists('modularform_search')) {
      modularform_search_solr_sync($entity, $type);
    }
  }
}

/**
 * Implements hook_entity_delete().
 */
function modularform_entity_delete($entity, $type) {
  // Handle form entity
  if ($type === 'modularform_form') {
    if (module_exists('modularform_search')) {
      modularform_search_solr_remove($entity->id, $type);
    }
  }

  // Handle response entity
  if ($type === 'modularform_response') {
    if (module_exists('modularform_search')) {
      modularform_search_solr_remove($entity->id, $type);
    }
  }
}

function modularform_restws_resource_info_alter(&$info) {
  $info['modularform_response']['class'] = 'ModularformResponseResource';
  $info['modularform_response']['menu_path'] = 'api/modularform/response';
}

function modularform_restws_response_alter(&$values, $function, $format_name, $resource_controller) {
  if (!$resource_controller instanceof ModularformResponseResource) {
    return;
  }
  if ($function !== 'viewResource') {
    return;
  }
  $id = $values['id'];
  // Replace entirely with your custom read() output
  $values = $resource_controller->read($id);
}

function modularform_file_download($uri) {
  if (strpos($uri, 'private://modularform/') !== 0 &&
    strpos($uri, 'temporary://modularform') !== 0) {
    return NULL;
  }

  if (user_access('answer forms') || user_access('view responses')) {
    $files = file_load_multiple([], ['uri' => $uri]);
    $file = reset($files);
    if ($file) {
      return [
        'Content-Type' => $file->filemime,
        'Content-Disposition' => 'attachment; filename="' . $file->filename . '"',
      ];
    }
  }

  return -1;
}

