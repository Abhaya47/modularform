// view page
function form_dashboard_page() {
  $header = [
    t('Name'),
    t('Owner'),
    t('Status'),
    t('Created'),
    t('Operations'),
  ];

  $rows = [];

  $forms = db_select('modularform_forms', 'f')
    ->fields('f', ['id', 'title', 'status', 'created_by', 'created_at'])
    ->orderBy('created_at', 'DESC')
    ->execute()
    ->fetchAll();

  // Batch load usernames
  $uids = array_unique(array_column((array) $forms, 'created_by'));
  $users = user_load_multiple($uids);

  foreach ($forms as $form) {
    $owner = isset($users[$form->created_by]) ? format_username($users[$form->created_by]) : t('Unknown');
    $status = $form->status ? t('Published') : t('Draft');
    $created = format_date($form->created_at, 'custom', 'M j Y');
    $links = array(
      'builder_preview' => array(
        'title' => t('Preview Survey'),
        'href' => 'forms/' . $form->id . '/builder/preview',
      ),
      'builder_edit' => array(
        'title' => t('Edit Survey'),
        'href' => 'forms/' . $form->id . '/builder/',
      ),
      'settings_edit' => array(
        'title' => t('Edit Settings'),
        'href' => 'forms/' . $form->id ,
      ),
    );

    $rows[] = [
      check_plain($form->title),
      check_plain($owner),
      $status,
      $created,
      $links,
    ];
  }

  if (empty($rows)) {
    $rows[] = [
      [
        'data' => t('No forms yet. !link', ['!link' => l(t('Create one'), 'forms/create')]),
        'colspan' => 5,
      ],
    ];
  }

  return [
    '#theme' => 'dashboard',
    '#header' => $header,
    '#rows' => $rows,
    '#attached' => [
      'css' => [drupal_get_path('module', 'modularform') . '/css/dashboard.css'],
    ],
  ];
}

// create page
function modularform_create_form($form, &$form_state, $id = NULL) {
  if ($id) {
    $modular_form = modularform_load($id);
  }
  else {
    $modular_form = NULL;
  }
  $form['id'] = [
    '#type' => 'hidden',
    '#default_value' => $modular_form ? $modular_form['id'] : '',
  ];

  $form['title'] = [
    '#type' => 'textfield',
    '#title' => t('Title'),
    '#required' => TRUE,
    '#default_value' => $modular_form ? $modular_form['title'] : 'Untitled form',
  ];

  $form['description'] = [
    '#type' => 'textfield',
    '#title' => t('Description'),
    '#required' => FALSE,
    '#default_value' => $modular_form ? $modular_form['description'] : '',
  ];

  $radio_options = [
    '0' => t('Drafted'),
    '1' => t('Published'),
  ];

  $form['status'] = [
    '#type' => 'radios',
    '#title' => t('Status'),
    '#options' => $radio_options,
    '#description' => t('Use one of the options below.'),
    '#required' => TRUE,
    '#default_value' => $modular_form ? $modular_form['status'] : 0,
  ];

  $form['closes_at'] = [
    '#type' => 'date',
    '#title' => t('Closes at'),
    '#required' => TRUE,
    '#default_value' => $modular_form ? $modular_form['closes_at'] : '',
  ];

  $form['submit'] = [
    '#type' => 'submit',
    '#value' => t('Start Building'),
    '#weight' => 20,
  ];

  $form['#theme'] = ['modularform_initial_template'];
  $form['#attached']['css'][] = drupal_get_path('module', 'modularform') . '/css/modularform-initial.css';

  return $form;
}

//modularform_create_form submit
function modularform_create_form_submit($form, &$form_state) {
  $values = $form_state['values'];
  $lang = 'und';
  $id = $values['id'];

  $controller = entity_get_controller('modularform_form');
  if (!empty($id)) {
    $entity = $controller->load($id);
  }
  else {
    $entity = $controller->create(['type' => 'organization']);
  }
  $entity->title = $values['title'];
  $entity->description = $values['description'];
  $entity->status = $values['status'];
  $entity->closes_at = $values['closes_at'];
  $entity->slug = modularform_generate_random_slug($values['title']);
  global $user;

  $entity->created_by = $user->uid;

  $now = (new DateTime('now', new DateTimeZone('UTC')))->getTimestamp();
  $entity->created_at = $now;
  $entity->updated_at = $now;
  $entity->save();
  $message = !empty($id) ? 'Form %title updated.' : 'Form %title saved in draft.';
  $fid = $entity->id;
  drupal_set_message(t($message, ['%title' => $entity->title]));
  drupal_goto("forms/$fid/builder");
}

/**
 * Generates a unique, URL-friendly slug from a title.
 */
function modularform_generate_random_slug($title) {
  $slug = preg_replace('/[^a-z0-9]+/', '_', strtolower($title));
  $slug = trim($slug, '_');

  // Generate a short 4-character random hex string
  $random_suffix = substr(md5(uniqid(mt_rand(), TRUE)), 0, 4);
  $final_slug = $slug . '_' . $random_suffix;

  // Check if slug exists
  if (_modularform_slug_exists($final_slug)) {
    return modularform_generate_random_slug($title);
  }

  return $final_slug;
}

/**
 * Internal helper to check the database for an existing slug.
 */
function _modularform_slug_exists($slug) {
  //  returns 1 if slug exists using the :slug placeholder for security.
  return db_query("SELECT 1 FROM {modularform_forms} WHERE slug = :slug", [':slug' => $slug])->fetchField();
}

//------------------
//------------------SURVEY BUILDER------------
//---------------------

// create survey
//data is stored in flat array bt form is in tree i.e. nested
function modularform_builder_form($form, &$form_state, $fid) {
  $form['#tree'] = TRUE;
  $form_state['storage']['fid'] = $fid;

  // ── Seed storage — DB on edit, blank on create ─────────────────────────────
  $is_edit = FALSE;

  if (empty($form_state['storage']['elements'])) {
    $loaded = _modularform_load_elements($fid);
    if ($loaded) {
      $is_edit = TRUE;
      $form_state['storage']['is_edit'] = TRUE;
      $form_state['storage']['elements'] = $loaded;
    }
    else {
      $first_sec_id = 'sec_' . $fid . '_' . uniqid();
      $form_state['storage']['elements'][$first_sec_id] = [
        'type' => 'section',
        'title' => 'Section 1',
        'weight' => 0,
        'parent' => NULL,
      ];
    }
  }
  else {
    $is_edit = $form_state['storage']['is_edit'] ?? FALSE;
  }

  $form['elements_container'] = [
    '#type' => 'container',
    '#attributes' => ['id' => ['modular-form-wrapper']],
  ];

  $elements = $form_state['storage']['elements'];

  // ── Sync question_type + add_validation changes from AJAX rebuilds ──────────
  if (!empty($form_state['values'])) {
    foreach ($elements as $id => $el) {
      if ($el['type'] == 'question') {
        $sec_id_lookup = $el['parent'];

        // ── Sync question_type ───────────────────────────────────────────────
        $path = ['elements_container', $sec_id_lookup, $id, 'question_type'];
        $submitted_type = drupal_array_get_nested_value($form_state['values'], $path);
        if (isset($submitted_type)) {
          $old_type = $form_state['storage']['elements'][$id]['question_type'] ?? 'text';
          $new_type = $submitted_type;
          $form_state['storage']['elements'][$id]['question_type'] = $new_type;
          $elements[$id]['question_type'] = $new_type;
          $had_options = in_array($old_type, ['radio', 'checkbox', 'dropdown', 'list', 'tag']);
          $has_options = in_array($new_type, ['radio', 'checkbox', 'dropdown', 'list', 'tag']);
          if ($had_options && !$has_options) {
            foreach ($form_state['storage']['elements'] as $child_id => $child_el) {
              if ($child_el['type'] === 'option' && $child_el['parent'] === $id) {
                unset($form_state['storage']['elements'][$child_id]);
              }
            }
          }
        }

        // ── Sync add_validation ──────────────────────────────────────────────
        $path = ['elements_container', $sec_id_lookup, $id, 'validation', 'add_validation'];
        $submitted_adv = drupal_array_get_nested_value($form_state['values'], $path);
        if (isset($submitted_adv)) {
          $was_enabled = $form_state['storage']['elements'][$id]['add_validation'] ?? FALSE;
          $now_enabled = (bool) $submitted_adv;
          $form_state['storage']['elements'][$id]['add_validation'] = $now_enabled;
          $elements[$id]['add_validation'] = $now_enabled;
          if ($was_enabled && !$now_enabled) {
            foreach ($form_state['storage']['elements'] as $child_id => $child_el) {
              if ($child_el['type'] === 'validation_rule' && $child_el['parent'] === $id) {
                unset($form_state['storage']['elements'][$child_id]);
              }
            }
          }
        }

        // ── Sync rule_type ───────────────────────────────────────────────────
        $q_val_rules = array_filter(
          $form_state['storage']['elements'],
          fn($el) => $el['type'] === 'validation_rule' && $el['parent'] === $id
        );
        foreach ($q_val_rules as $r_id => $r_el) {
          $path = ['elements_container', $sec_id_lookup, $id, 'validation', 'adv_rules', $r_id, 'rule_type'];
          $submitted_rule_type = drupal_array_get_nested_value($form_state['values'], $path);
          if (isset($submitted_rule_type)) {
            $form_state['storage']['elements'][$r_id]['rule_type'] = $submitted_rule_type;
            $elements[$r_id]['rule_type'] = $submitted_rule_type;
          }
        }

      }
    }
  }

  // ── Render ──────────────────────────────────────────────────────────────────
  $sections = array_filter($elements, fn($el) => $el['type'] == 'section');
  $questions = array_filter($elements, fn($el) => $el['type'] == 'question');
  $options = array_filter($elements, fn($el) => $el['type'] == 'option');
  $val_rules = array_filter($elements, fn($el) => $el['type'] === 'validation_rule');

  $section_keys = array_keys($sections);

  foreach ($sections as $sec_id => $sec_el) {
    $form['elements_container'][$sec_id] = [
      '#type' => 'container',
      '#attributes' => [
        'id' => 'section-wrapper-' . $sec_id,
        'class' => ['depth-section'],
      ],
    ];

    $form['elements_container'][$sec_id]['title'] = [
      '#type' => 'textfield',
      '#title' => t('Section Title'),
      '#default_value' => $sec_el['title'] ?? '',  // ← edit
    ];

    $section_questions = array_filter($questions, fn($el) => $el['parent'] == $sec_id);

    foreach ($section_questions as $q_id => $q_el) {
      $q_type = $q_el['question_type'] ?? 'text';
      $show_adv_val = $q_el['add_validation'] ?? FALSE;

      $form['elements_container'][$sec_id][$q_id] = [
        '#type' => 'container',
        '#attributes' => [
          'id' => 'question-wrapper-' . $q_id,
          'class' => ['depth-question'],
        ],
      ];

      $form['elements_container'][$sec_id][$q_id]['question_text'] = [
        '#type' => 'textfield',
        '#title' => t('Question'),
        '#default_value' => $q_el['label'] ?? '',  // ← edit
      ];

      $form['elements_container'][$sec_id][$q_id]['question_type'] = [
        '#type'          => 'select',
        '#title'         => t('Question Type'),
        '#options'       => [
          'text'      => t('Short Answer'),
          'textarea'  => t('Paragraph'),
          'richtext'  => t('Rich Text'),
          'date'      => t('Date'),
          'time'      => t('Time'),
          'list'      => t('List'),
          'radio'     => t('Multiple Choice'),
          'boolean'   => t('Yes / No'),
          'checkbox'  => t('Checkbox'),
          'dropdown'  => t('Dropdown'),
          'file'      => t('File'),
          'tag'       => t('Tag'),
        ],
        '#default_value' => $q_type,
        '#ajax'          => [
          'callback' => 'modularform_ajax_question_callback',
          'wrapper'  => 'question-wrapper-' . $q_id,
          'event'    => 'change',
        ],
      ];

      // Types that need options managed
      switch ($q_type) {

        case 'text':
          $form['elements_container'][$sec_id][$q_id]['preview'] = [
            '#markup' => '<p class="field-preview">Short answer text field</p>',
          ];
          break;

        case 'textarea':
          $form['elements_container'][$sec_id][$q_id]['preview'] = [
            '#markup' => '<p class="field-preview">Long answer text area</p>',
          ];
          break;

        case 'richtext':
          $form['elements_container'][$sec_id][$q_id]['preview'] = [
            '#markup' => '<p class="field-preview">Rich text editor (TinyMCE)</p>',
          ];
          break;

        case 'date':
          $form['elements_container'][$sec_id][$q_id]['preview'] = [
            '#markup' => '<p class="field-preview">Date picker</p>',
          ];
          break;

        case 'time':
          $form['elements_container'][$sec_id][$q_id]['preview'] = [
            '#markup' => '<p class="field-preview">Time picker</p>',
          ];
          break;

        case 'boolean':
          $form['elements_container'][$sec_id][$q_id]['preview'] = [
            '#markup' => '<p class="field-preview">Yes / No</p>',
          ];
          break;

        case 'file':
          $form['elements_container'][$sec_id][$q_id]['file_settings'] = [
            '#type'  => 'container',
            '#attributes' => ['class' => ['file-settings']],
          ];
          $form['elements_container'][$sec_id][$q_id]['file_settings']['multiple'] = [
            '#type'          => 'checkbox',
            '#title'         => t('Allow multiple files'),
            '#default_value' => $q_el['file_multiple'] ?? 0,
          ];
          $form['elements_container'][$sec_id][$q_id]['preview'] = [
            '#markup' => '<p class="field-preview">File upload field</p>',
          ];
          break;

        case 'radio':
        case 'checkbox':
        case 'dropdown':
        case 'list':
        case 'tag':
          $question_options = array_filter($options, fn($el) => $el['parent'] == $q_id);

          foreach ($question_options as $o_id => $o_el) {
            $form['elements_container'][$sec_id][$q_id][$o_id] = [
              '#type'       => 'container',
              '#attributes' => ['class' => ['depth-option']],
            ];
            $form['elements_container'][$sec_id][$q_id][$o_id]['option_label'] = [
              '#type'          => 'textfield',
              '#title'         => t('Option'),
              '#default_value' => $o_el['option'] ?? '',
              '#required'      => TRUE,
            ];
            $form['elements_container'][$sec_id][$q_id][$o_id]['delete'] = [
              '#type'                  => 'submit',
              '#value'                 => t('Delete'),
              '#name'                  => 'delete_' . $o_id,
              '#submit'                => ['modularform_delete_element_submit'],
              '#ajax'                  => [
                'callback' => 'modularform_ajax_question_callback',
                'wrapper'  => 'question-wrapper-' . $q_id,
              ],
              '#limit_validation_errors' => [],
            ];
          }

          // Dropdown gets a multiselect toggle
          if ($q_type === 'dropdown') {
            $form['elements_container'][$sec_id][$q_id]['dropdown_multiple'] = [
              '#type'          => 'checkbox',
              '#title'         => t('Allow multiple selections'),
              '#default_value' => $q_el['dropdown_multiple'] ?? 0,
            ];
          }

          $form['elements_container'][$sec_id][$q_id]['add_opt'] = [
            '#type'   => 'submit',
            '#value'  => t('+ Add Option'),
            '#name'   => 'add_opt_' . $q_id,
            '#submit' => ['modularform_add_element_submit'],
            '#ajax'   => [
              'callback' => 'modularform_ajax_question_callback',
              'wrapper'  => 'question-wrapper-' . $q_id,
            ],
          ];
          break;
      }

      $form['elements_container'][$sec_id][$q_id]['validation'] = [
        '#type' => 'container',
        '#attributes' => [
          'id' => 'validation-wrapper-' . $q_id,
          'class' => ['question-validation-block'],
        ],
      ];

      $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'] = [
        '#type' => 'container',
        '#attributes' => [
          'id' => 'adv-validation-wrapper-' . $q_id,
          'class' => ['adv-validation-block'],
        ],
      ];

      if ($show_adv_val) {
        $q_val_rules = array_filter($val_rules, fn($el) => $el['parent'] === $q_id);

        foreach ($q_val_rules as $r_id => $r_el) {
          $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id] = [
            '#type' => 'container',
            '#attributes' => ['class' => ['adv-rule-row']], // Add this line
          ];
          // The rest of your code remains the same...
          $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id]['rule_type'] = [
            '#type'          => 'select',
            '#title'         => t('Rule'),
            '#options'       => _modularform_validation_rule_options($q_type),
            '#default_value' => $r_el['rule_type'] ?? '',
            '#ajax'          => [
              'callback' => 'modularform_ajax_rule_value_callback',
              'wrapper'  => 'rule-value-wrapper-' . $r_id,
              'event'    => 'change',
            ],
          ];

          $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id]['rule_value_wrapper'] = [
            '#type' => 'container',
            '#attributes' => [
              'id' => 'rule-value-wrapper-' . $r_id,
            ],
          ];

          $current_rule_type = $r_el['rule_type'] ?? '';


          $value_type = _modularform_rule_value_type($q_type, $current_rule_type);

          switch ($value_type) {
            case 'none':
              $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id]['rule_value_wrapper']['rule_value'] = [
                '#markup' => '<p class="rule-no-value">' . t('No value required for this rule.') . '</p>',
              ];
              break;

            case 'number':
              $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id]['rule_value_wrapper']['rule_value'] = [
                '#type'             => 'textfield',
                '#title'            => t('Value'),
                '#default_value'    => $r_el['rule_value'] ?? '',
                '#size'             => 10,
                '#element_validate' => ['element_validate_number'],
              ];
              break;

            case 'select':
              $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id]['rule_value_wrapper']['rule_value'] = [
                '#type'          => 'select',
                '#title'         => t('Value'),
                '#options'       => _modularform_rule_value_options($q_type, $current_rule_type),
                '#default_value' => $r_el['rule_value'] ?? '',
              ];
              break;

            case 'text':
            default:
              $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id]['rule_value_wrapper']['rule_value'] = [
                '#type'          => 'textfield',
                '#title'         => t('Value'),
                '#default_value' => $r_el['rule_value'] ?? '',
              ];
              break;
          }

          $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id]['error_message'] = [
            '#type' => 'textfield',
            '#title' => t('Custom error message'),
            '#placeholder' => t('Optional'),
            '#default_value' => $r_el['error_message'] ?? '',  // ← edit
          ];

          $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id]['delete'] = [
            '#type' => 'submit',
            '#value' => t('Delete'),
            '#name' => 'delete_' . $r_id,
            '#submit' => ['modularform_delete_element_submit'],
            '#ajax' => [
              'callback' => 'modularform_ajax_validation_callback',
              'wrapper' => 'adv-validation-wrapper-' . $q_id,
            ],
            '#limit_validation_errors' => [],
            '#attributes' => [
              'class' => ['btn-delete-red'], // Class for our red styling
            ],
          ];
        }

        $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules']['add_rule'] = [
          '#type' => 'submit',
          '#value' => t('+ Add Rule'),
          '#name' => 'add_rule_' . $q_id,
          '#submit' => ['modularform_add_element_submit'],
          '#ajax' => [
            'callback' => 'modularform_ajax_validation_callback',
            'wrapper' => 'adv-validation-wrapper-' . $q_id,
          ],
        ];
      }

      $form['elements_container'][$sec_id][$q_id]['validation']['is_required'] = [
        '#type' => 'checkbox',
        '#title' => t('Required'),
        '#default_value' => $q_el['is_required'] ?? 0,  // ← edit
      ];

      $form['elements_container'][$sec_id][$q_id]['validation']['add_validation'] = [
        '#type' => 'checkbox',
        '#title' => t('Add validation rules'),
        '#default_value' => $show_adv_val ? 1 : 0,  // ← edit
        '#ajax' => [
          'callback' => 'modularform_ajax_validation_callback',
          'wrapper' => 'adv-validation-wrapper-' . $q_id,
          'event' => 'change',
        ],
      ];

      $form['elements_container'][$sec_id][$q_id]['delete'] = [
        '#type' => 'submit',
        '#value' => t('Delete Question'),
        '#name' => 'delete_' . $q_id,
        '#submit' => ['modularform_delete_element_submit'],
        '#ajax' => [
          'callback' => 'modularform_ajax_section_callback',
          'wrapper' => 'section-wrapper-' . $sec_id,
        ],
        '#limit_validation_errors' => [],
      ];
    }

    $form['elements_container'][$sec_id]['add_q'] = [
      '#type' => 'submit',
      '#value' => t('+ Add Question'),
      '#name' => 'add_q_' . $sec_id,
      '#submit' => ['modularform_add_element_submit'],
      '#ajax' => [
        'callback' => 'modularform_ajax_section_callback',
        'wrapper' => 'section-wrapper-' . $sec_id,
      ],
    ];

    if ($sec_id !== $section_keys[0]) {
      $form['elements_container'][$sec_id]['delete'] = [
        '#type' => 'submit',
        '#value' => t('Delete Section'),
        '#name' => 'delete_' . $sec_id,
        '#submit' => ['modularform_delete_element_submit'],
        '#ajax' => [
          'callback' => 'modularform_ajax_top_callback',
          'wrapper' => 'modular-form-wrapper',
        ],
        '#limit_validation_errors' => [],
      ];
    }
  }

  $form['elements_container']['add_section'] = [
    '#type' => 'submit',
    '#value' => t('+ Add Section'),
    '#name' => 'add_section',
    '#submit' => ['modularform_add_element_submit'],
    '#ajax' => [
      'callback' => 'modularform_ajax_top_callback',
      'wrapper' => 'modular-form-wrapper',
    ],
  ];

  $form['elements_container']['add_element'] = [
    '#type' => 'submit',
    '#value' => $is_edit ? t('Update survey') : t('Create survey'),
  ];

  return $form;
}

function modularform_add_element_submit($form, &$form_state) {
  $trigger = $form_state['triggering_element']['#name'];
  $fid = $form_state['storage']['fid'];

  if ($trigger === 'add_section') {
    $new_id = 'sec_' . $fid . '_' . uniqid();
    $siblings = array_filter($form_state['storage']['elements'], fn($el) => $el['type'] === 'section');
    $sec_count = count($siblings);
    $form_state['storage']['elements'][$new_id] = [
      'type' => 'section',
      'title' => 'Section ' . ($sec_count + 1),
      'weight' => $siblings ? max(array_column($siblings, 'weight')) + 1 : 0,
      'parent' => NULL,
    ];
  }
  elseif (strpos($trigger, 'add_q_') === 0) {
    $new_id = 'q_' . $fid . '_' . uniqid();
    $parent_id = str_replace('add_q_', '', $trigger);
    $siblings = array_filter($form_state['storage']['elements'], fn($el) => $el['type'] === 'question' && $el['parent'] === $parent_id);
    $form_state['storage']['elements'][$new_id] = [
      'type' => 'question',
      'parent' => $parent_id,
      'question_type' => 'text',
      'weight' => $siblings ? max(array_column($siblings, 'weight')) + 1 : 0,
    ];
  }
  elseif (strpos($trigger, 'add_opt_') === 0) {
    $new_id = 'opt_' . $fid . '_' . uniqid();
    $parent_id = str_replace('add_opt_', '', $trigger);
    $siblings = array_filter($form_state['storage']['elements'], fn($el) => $el['type'] === 'option' && $el['parent'] === $parent_id);
    $form_state['storage']['elements'][$new_id] = [
      'type' => 'option',
      'parent' => $parent_id,
      'weight' => $siblings ? max(array_column($siblings, 'weight')) + 1 : 0,
    ];
  }
  elseif (strpos($trigger, 'add_rule_') === 0) {
    $new_id = 'r_' . $fid . '_' . uniqid();
    $q_id = substr($trigger, strlen('add_rule_'));
    $siblings = array_filter($form_state['storage']['elements'], fn($el) => $el['type'] === 'validation_rule' && $el['parent'] === $q_id);
    $form_state['storage']['elements'][$new_id] = [
      'type' => 'validation_rule',
      'parent' => $q_id,
      'rule_type' => '',
      'weight' => $siblings ? max(array_column($siblings, 'weight')) + 1 : 0,
    ];
  }

  $form_state['rebuild'] = TRUE;
}

/**
 * Load all elements for a form from DB into the storage flat-list format.
 * Returns empty array if form has no saved elements (create flow).
 */
function _modularform_load_elements($fid) {
  $elements = [];

  $type_map_flip = [
    0  => 'text',
    1  => 'textarea',
    2  => 'radio',
    3  => 'boolean',
    4  => 'checkbox',
    5  => 'file',
    6  => 'dropdown',
    7  => 'tag',
    8  => 'richtext',
    9  => 'date',
    10 => 'time',
    11 => 'list',
  ];

  // Sections
  $sections = db_select('modularform_sections', 's')
    ->fields('s', ['sec_id', 'name', 'weight'])
    ->condition('form_id', $fid)
    ->orderBy('weight')
    ->execute()
    ->fetchAllAssoc('sec_id', PDO::FETCH_ASSOC);

  if (empty($sections)) {
    return [];
  }

  foreach ($sections as $sec_id => $row) {
    $elements[$sec_id] = [
      'type' => 'section',
      'title' => $row['name'],
      'weight' => (int) $row['weight'],
      'parent' => NULL,
    ];
  }

  // Questions
  $questions = db_select('modularform_questions', 'q')
    ->fields('q', [
      'q_id',
      'sec_id',
      'label',
      'type',
      'is_required',
      'position',
    ])
    ->condition('form_id', $fid)
    ->orderBy('sec_id')
    ->orderBy('position')
    ->execute()
    ->fetchAllAssoc('q_id', PDO::FETCH_ASSOC);

  foreach ($questions as $q_id => $row) {
    $elements[$q_id] = [
      'type' => 'question',
      'parent' => $row['sec_id'],
      'label' => $row['label'],
      'question_type' => $type_map_flip[$row['type']] ?? 'text',
      'is_required' => (bool) $row['is_required'],
      'add_validation' => FALSE,  // overridden below if rules exist
      'weight' => (int) $row['position'],
    ];
  }

  // Options
  $options = db_select('modularform_question_options', 'o')
    ->fields('o', ['o_id', 'q_id', 'option', 'weight'])
    ->condition('form_id', $fid)
    ->orderBy('q_id')
    ->orderBy('weight')
    ->execute()
    ->fetchAllAssoc('o_id', PDO::FETCH_ASSOC);

  foreach ($options as $o_id => $row) {
    $elements[$o_id] = [
      'type' => 'option',
      'parent' => $row['q_id'],
      'option' => $row['option'],
      'weight' => (int) $row['weight'],
    ];
  }

  // Validation rules
  $rules = db_select('modularform_validation_rules', 'r')
    ->fields('r', [
      'r_id',
      'q_id',
      'rule_type',
      'rule_value',
      'error_message',
      'weight',
    ])
    ->condition('form_id', $fid)
    ->orderBy('q_id')
    ->orderBy('weight')
    ->execute()
    ->fetchAllAssoc('r_id', PDO::FETCH_ASSOC);

  foreach ($rules as $r_id => $row) {
    // Flag the parent question so the rule-builder renders open
    if (isset($elements[$row['q_id']])) {
      $elements[$row['q_id']]['add_validation'] = TRUE;
    }
    $elements[$r_id] = [
      'type' => 'validation_rule',
      'parent' => $row['q_id'],
      'rule_type' => $row['rule_type'],
      'rule_value' => $row['rule_value'],
      'error_message' => $row['error_message'],
      'weight' => (int) $row['weight'],
    ];
  }

  return $elements;
}

//deletion case
function modularform_delete_element_submit($form, &$form_state) {
  $trigger = $form_state['triggering_element']['#name'];
  $target_id = str_replace('delete_', '', $trigger);
  $elements = &$form_state['storage']['elements'];

  // ✅ Save parent info BEFORE unset
  $form_state['storage']['last_deleted'] = [
    'id' => $target_id,
    'type' => $elements[$target_id]['type'],
    'parent' => $elements[$target_id]['parent'],
  ];

  $ids_to_remove = modularform_collect_descendants($target_id, $elements);
  $ids_to_remove[] = $target_id;

  foreach ($ids_to_remove as $id) {
    unset($elements[$id]);
  }

  $form_state['rebuild'] = TRUE;
}

//if you delete a question it's options must go too
/**
 * Recursively finds all descendant IDs of a given element.
 */
function modularform_collect_descendants($parent_id, $elements) {
  $descendants = [];
  foreach ($elements as $id => $el) {
    if ($el['parent'] === $parent_id) {
      $descendants[] = $id;
      // Recurse to catch grandchildren (e.g. options under a question)
      $descendants = array_merge(
        $descendants,
        modularform_collect_descendants($id, $elements)
      );
    }
  }
  return $descendants;
}

function modularform_ajax_top_callback($form, $form_state) {
  return $form['elements_container'];
}

function modularform_ajax_section_callback($form, $form_state) {
  $trigger = $form_state['triggering_element']['#name'];

  if (strpos($trigger, 'add_q_') === 0) {
    $sec_id = str_replace('add_q_', '', $trigger);
  }
  else {
    $target = modularform_get_delete_target($form_state); // ← no $elements arg
    $sec_id = $target['sec_id'];
  }

  return $form['elements_container'][$sec_id];
}

function modularform_ajax_question_callback($form, $form_state) {
  $trigger = $form_state['triggering_element']['#name'];
  $parents = $form_state['triggering_element']['#parents'];
  $elements = $form_state['storage']['elements'];

  if (strpos($trigger, 'add_opt_') === 0) {
    $q_id = str_replace('add_opt_', '', $trigger);
  }
  elseif (strpos($trigger, 'delete_') === 0) {
    $target = modularform_get_delete_target($form_state);
    $q_id = $target['q_id'];
  }
  else {
    $q_id = $parents[2];
  }

  $sec_id = $elements[$q_id]['parent'];
  return $form['elements_container'][$sec_id][$q_id];
}

function modularform_ajax_validation_callback($form, &$form_state) {
  $parents = $form_state['triggering_element']['#parents'];
  // Log it so we can see the actual structure
  watchdog('modularform', 'AJAX parents: <pre>@p</pre>', ['@p' => print_r($parents, TRUE)]);

  $sec_id = $parents[1];
  $q_id = $parents[2];

  return $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'];
}

function modularform_ajax_rule_value_callback($form, &$form_state) {
  $parents = $form_state['triggering_element']['#parents'];
  // parents: [elements_container, sec_id, q_id, validation, adv_rules, r_id, rule_type]
  $sec_id = $parents[1];
  $q_id   = $parents[2];
  $r_id   = $parents[5];

  return $form['elements_container'][$sec_id][$q_id]['validation']['adv_rules'][$r_id]['rule_value_wrapper'];
}

/**
 * Returns the form element path needed to rebuild after a delete.
 *
 * @param string $deleted_id
 *   The ID of the element being deleted.
 * @param array $elements
 *   The flat storage array from $form_state['storage']['elements'].
 *
 * @return array
 *   ['type' => 'section'|'question', 'sec_id' => ..., 'q_id' => ...]
 */
function modularform_get_delete_target($form_state) {
  $last = $form_state['storage']['last_deleted'];

  if ($last['type'] == 'question') {
    return [
      'type' => 'section',
      'sec_id' => $last['parent'],
    ];
  }

  if ($last['type'] == 'option') {
    $q_id = $last['parent'];
    return [
      'type' => 'question',
      'q_id' => $q_id,
      'sec_id' => $form_state['storage']['elements'][$q_id]['parent'],
    ];
  }
}

// The final save handler
function modularform_builder_form_submit($form, &$form_state) {
  $fid = $form_state['storage']['fid'];
  $elements = $form_state['storage']['elements'];
  $values = $form_state['values']['elements_container'];
  $now = REQUEST_TIME;

  $sections = array_filter($elements, fn($el) => $el['type'] === 'section');
  $questions = array_filter($elements, fn($el) => $el['type'] === 'question');
  $options = array_filter($elements, fn($el) => $el['type'] === 'option');
  $val_rules = array_filter($elements, fn($el) => $el['type'] === 'validation_rule');

  uasort($sections, fn($a, $b) => $a['weight'] <=> $b['weight']);
  uasort($questions, fn($a, $b) => $a['weight'] <=> $b['weight']);
  uasort($options, fn($a, $b) => $a['weight'] <=> $b['weight']);
  uasort($val_rules, fn($a, $b) => $a['weight'] <=> $b['weight']);

  $type_map = [
    'text'      => 0,
    'textarea'  => 1,
    'radio'     => 2,
    'boolean'   => 3,
    'checkbox'  => 4,
    'file'      => 5,
    'dropdown'  => 6,
    'tag'       => 7,
    'richtext'  => 8,   // ← add
    'date'      => 9,   // ← add
    'time'      => 10,  // ← add
    'list'      => 11,  // ← add
  ];

  $datatype_map = [
    'text'      => 'varchar',
    'textarea'  => 'text',
    'richtext'  => 'text',    // ← add
    'radio'     => 'int',
    'boolean'   => 'bool',
    'checkbox'  => 'int',
    'file'      => 'varchar',
    'dropdown'  => 'int',
    'tag'       => 'int',
    'date'      => 'date',    // ← add
    'time'      => 'varchar', // ← add
    'list'      => 'int',     // ← add
  ];

  // ── 1. Bulk deletes — children before parents ──────────────────────────────
  $live_sec_ids = array_keys($sections) ?: [''];
  $live_q_ids = array_keys($questions) ?: [''];
  $live_o_ids = array_keys($options) ?: [''];
  $live_r_ids = array_keys($val_rules) ?: [''];

  db_delete('modularform_validation_rules')
    ->condition('form_id', $fid)
    ->condition('r_id', $live_r_ids, 'NOT IN')
    ->execute();

  db_delete('modularform_question_options')
    ->condition('form_id', $fid)
    ->condition('o_id', $live_o_ids, 'NOT IN')
    ->execute();

  db_delete('modularform_questions')
    ->condition('form_id', $fid)
    ->condition('q_id', $live_q_ids, 'NOT IN')
    ->execute();

  db_delete('modularform_sections')
    ->condition('form_id', $fid)
    ->condition('sec_id', $live_sec_ids, 'NOT IN')
    ->execute();

  // ── 2. Upsert sections ─────────────────────────────────────────────────────
  foreach ($sections as $sec_id => $sec_el) {
    $name = $values[$sec_id]['title'] ?? $sec_el['title'] ?? '';

    db_merge('modularform_sections')
      ->key(['sec_id' => $sec_id])
      ->insertFields([
        'sec_id' => $sec_id,
        'form_id' => $fid,
        'name' => $name,
        'weight' => $sec_el['weight'],
        'created_at' => $now,
        'updated_at' => $now,
      ])
      ->updateFields([
        'name' => $name,
        'weight' => $sec_el['weight'],
        'updated_at' => $now,
      ])
      ->execute();
  }

  // ── 3. Upsert questions ────────────────────────────────────────────────────
  $position_counter = [];

  foreach ($questions as $q_id => $q_el) {
    $sec_id = $q_el['parent'];
    $q_type_str = $q_el['question_type'] ?? 'text';
    $q_vals = $values[$sec_id][$q_id] ?? [];

    $position = $position_counter[$sec_id] ?? 0;
    $position_counter[$sec_id] = $position + 1;

    $q_fields_insert = [
      'q_id' => $q_id,
      'form_id' => $fid,
      'sec_id' => $sec_id,
      'label' => $q_vals['question_text'] ?? '',
      'type' => $type_map[$q_type_str] ?? 0,
      'datatype' => $datatype_map[$q_type_str] ?? 'varchar',
      'is_required' => (int) ($q_vals['validation']['is_required'] ?? 0),
      'position' => $position,
      'created_at' => $now,
      'updated_at' => $now,
    ];

    db_merge('modularform_questions')
      ->key(['q_id' => $q_id])
      ->insertFields($q_fields_insert)
      ->updateFields([
        'sec_id'            => $sec_id,
        'label'             => $q_fields_insert['label'],
        'type'              => $q_fields_insert['type'],
        'datatype'          => $q_fields_insert['datatype'],
        'is_required'       => $q_fields_insert['is_required'],
        'position'          => $position,
        'updated_at'        => $now,
      ])
      ->execute();
  }

  // ── 4. Upsert options ──────────────────────────────────────────────────────
  foreach ($options as $o_id => $o_el) {
    $q_id = $o_el['parent'];
    $sec_id = $questions[$q_id]['parent'] ?? NULL;
    $label = $values[$sec_id][$q_id][$o_id]['option_label'] ?? '';

    db_merge('modularform_question_options')
      ->key(['o_id' => $o_id])
      ->insertFields([
        'o_id' => $o_id,
        'q_id' => $q_id,
        'form_id' => $fid,
        'option' => $label,
        'weight' => $o_el['weight'],
        'created_at' => $now,
        'updated_at' => $now,
      ])
      ->updateFields([
        'option' => $label,
        'weight' => $o_el['weight'],
        'updated_at' => $now,
      ])
      ->execute();
  }

  // ── 5. Upsert validation rules ─────────────────────────────────────────────
  foreach ($val_rules as $r_id => $r_el) {
    $q_id = $r_el['parent'];
    $sec_id = $questions[$q_id]['parent'] ?? NULL;
    $r_vals = $values[$sec_id][$q_id]['validation']['adv_rules'][$r_id] ?? [];

    db_merge('modularform_validation_rules')
      ->key(['r_id' => $r_id])
      ->insertFields([
        'r_id' => $r_id,
        'q_id' => $q_id,
        'form_id' => $fid,
        'rule_type' => $r_vals['rule_type'] ?? '',
        'rule_value' => $r_vals['rule_value_wrapper']['rule_value'] ?? '',
        'error_message' => $r_vals['error_message'] ?? '',
        'weight' => $r_el['weight'],
        'created_at' => $now,
        'updated_at' => $now,
      ])
      ->updateFields([
        'rule_type' => $r_vals['rule_type'] ?? '',
        'rule_value' => $r_vals['rule_value_wrapper']['rule_value'] ?? '',
        'error_message' => $r_vals['error_message'] ?? '',
        'weight' => $r_el['weight'],
        'updated_at' => $now,
      ])
      ->execute();
  }

  // ── 6. Touch parent form ───────────────────────────────────────────────────
  db_update('modularform_forms')
    ->fields(['updated_at' => $now])
    ->condition('id', $fid)
    ->execute();

  drupal_set_message(t('Survey saved successfully.'));
  $form_state['redirect'] = '/forms/' . $fid . '/builder/preview';
}

/**
 * Preview function
 */
function modularform_preview_form($form, &$form_state, $fid) {
  $elements = _modularform_load_elements($fid);
  $form['#attributes']['class'][] = 'modularform-preview-form';
  if (empty($elements)) {
    $form['empty'] = ['#markup' => '<p>' . t('No form elements found.') . '</p>'];
    return $form;
  }

  $sections  = array_filter($elements, fn($el) => $el['type'] === 'section');
  $questions = array_filter($elements, fn($el) => $el['type'] === 'question');
  $options   = array_filter($elements, fn($el) => $el['type'] === 'option');
  $val_rules = array_filter($elements, fn($el) => $el['type'] === 'validation_rule');

  uasort($sections,  fn($a, $b) => $a['weight'] <=> $b['weight']);
  uasort($questions, fn($a, $b) => $a['weight'] <=> $b['weight']);

  // Derive file_multiple and dropdown_multiple from validation rules
  foreach ($questions as $q_id => &$q) {
    $q_rules = array_filter($val_rules, fn($r) => $r['parent'] === $q_id);
    if ($q['question_type'] === 'file') {
      foreach ($q_rules as $r) {
        if ($r['rule_type'] === 'max_files' && (int) $r['rule_value'] > 1) {
          $q['file_multiple'] = TRUE;
        }
      }
    }
    if ($q['question_type'] === 'dropdown') {
      foreach ($q_rules as $r) {
        if ($r['rule_type'] === 'max_selections' && (int) $r['rule_value'] > 1) {
          $q['dropdown_multiple'] = TRUE;
        }
      }
    }
  }
  unset($q);

  // Attach Select2 library and our preview JS/CSS
  $form['#attached']['library'][]        = ['modularform', 'select2'];
  $form['#attached']['js'][]             = drupal_get_path('module', 'modularform') . '/js/modularform.preview.js';
  $form['#attached']['css'][]            = drupal_get_path('module', 'modularform') . '/css/modularform.preview.css';

  // Pass validation rules to JS for client-side validation
  $js_rules = [];
  foreach ($questions as $q_id => $q) {
    $q_rules = array_filter($val_rules, fn($r) => $r['parent'] === $q_id);
    if (!empty($q_rules)) {
      foreach ($q_rules as $r) {
        $js_rules[$q_id][] = [
          'rule_type'     => $r['rule_type'],
          'rule_value'    => $r['rule_value'],
          'error_message' => $r['error_message'] ?? '',
          'q_type'        => $q['question_type'],
        ];
      }
    }
  }
  $form['#attached']['js'][] = [
    'data' => ['modularformPreview' => ['rules' => $js_rules]],
    'type' => 'setting',
  ];

  $form['#tree'] = TRUE;
  $form['#attributes']['enctype'] = 'multipart/form-data';

  foreach ($sections as $sec_id => $sec) {
    $form[$sec_id] = [
      '#type'       => 'container',
      '#attributes' => ['class' => ['preview-section']],
    ];

    $form[$sec_id]['_title'] = [
      '#markup' => '<h3 class="preview-section-title">' . check_plain($sec['title']) . '</h3>',
    ];

    $sec_questions = array_filter($questions, fn($q) => $q['parent'] === $sec_id);
    uasort($sec_questions, fn($a, $b) => $a['weight'] <=> $b['weight']);

    foreach ($sec_questions as $q_id => $q) {
      $q_type   = $q['question_type'] ?? 'text';
      $label    = $q['label'] ?? '';
      $required = !empty($q['is_required']);

      $q_options = array_filter($options, fn($o) => $o['parent'] === $q_id);
      uasort($q_options, fn($a, $b) => $a['weight'] <=> $b['weight']);
      $options_list = [];
      foreach ($q_options as $o) {
        $val = check_plain($o['option']);
        $options_list[$val] = $val;
      }

      $form[$sec_id][$q_id] = [
        '#type'       => 'container',
        '#attributes' => [
          'class'        => ['preview-question'],
          'data-q-id'    => $q_id,
          'data-q-type'  => $q_type,
        ],
      ];

      switch ($q_type) {

        case 'text':
          $form[$sec_id][$q_id]['answer'] = [
            '#type'       => 'textfield',
            '#title'      => $label,
            '#required'   => $required,
            '#attributes' => ['data-q-id' => $q_id],
          ];
          break;

        case 'textarea':
          $form[$sec_id][$q_id]['answer'] = [
            '#type'       => 'textarea',
            '#title'      => $label,
            '#rows'       => 5,
            '#required'   => $required,
            '#attributes' => ['data-q-id' => $q_id],
          ];
          break;

        case 'richtext':
          $form[$sec_id][$q_id]['answer'] = [
            '#type'       => 'textarea',
            '#title'      => $label,
            '#required'   => $required,
            '#rows'       => 8,
            '#attributes' => [
              'data-q-id' => $q_id,
              'class'     => ['tinymce-editor'],
            ],
          ];
          break;

        case 'date':
          $form[$sec_id][$q_id]['answer'] = [
            '#type'       => 'date',
            '#title'      => $label,
            '#required'   => $required,
            '#attributes' => ['data-q-id' => $q_id],
          ];
          break;

        case 'time':
          $form[$sec_id][$q_id]['answer'] = [
            '#type'       => 'textfield',
            '#title'      => $label,
            '#required'   => $required,
            '#attributes' => ['type' => 'time', 'data-q-id' => $q_id],
          ];
          break;

        case 'boolean':
          $form[$sec_id][$q_id]['answer'] = [
            '#type'       => 'radios',
            '#title'      => $label,
            '#options'    => ['yes' => t('Yes'), 'no' => t('No')],
            '#required'   => $required,
            '#attributes' => ['data-q-id' => $q_id],
          ];
          break;

        case 'radio':
          $form[$sec_id][$q_id]['answer'] = [
            '#type'       => 'radios',
            '#title'      => $label,
            '#options'    => $options_list,
            '#required'   => $required,
            '#attributes' => ['data-q-id' => $q_id],
          ];
          break;

        case 'list':
        case 'checkbox':
          $form[$sec_id][$q_id]['answer'] = [
            '#type'       => 'checkboxes',
            '#title'      => $label,
            '#options'    => $options_list,
            '#required'   => $required,
            '#attributes' => ['data-q-id' => $q_id],
          ];
          break;

        case 'dropdown':
          $is_multiple = !empty($q['dropdown_multiple']);
          $form[$sec_id][$q_id]['answer'] = [
            '#type'         => 'select',
            '#title'        => $label,
            '#options'      => $options_list,
            '#empty_option' => $is_multiple ? NULL : t('- Select -'),
            '#required'     => $required,
            '#multiple'     => $is_multiple,
            '#attributes'   => [
              'data-q-id'    => $q_id,
              'class'        => ['select2-enable'],
            ],
          ];
          break;

        case 'tag':
          $form[$sec_id][$q_id]['answer'] = [
            '#type'       => 'select',
            '#title'      => $label,
            '#options'    => $options_list,
            '#required'   => $required,
            '#multiple'   => TRUE,
            '#attributes' => [
              'data-q-id' => $q_id,
              'class'     => ['select2-enable', 'select2-tags'],
            ],
          ];
          break;

        case 'file':
          $is_multiple = !empty($q['file_multiple']);
          $form[$sec_id][$q_id]['answer'] = [
            '#type'              => 'managed_file',
            '#title'             => $label,
            '#required'          => $required,
            '#upload_location'   => 'temporary://modularform_preview',
            '#upload_validators' => [
              'file_validate_size' => [25 * 1024 * 1024],
            ],
            '#multiple'          => $is_multiple,
            '#description'       => t('Preview only — file will not be saved.'),
            '#attributes'        => ['data-q-id' => $q_id],
          ];
          break;
      }
    }
  }

  // No submit button.
  return $form;
}


/**
 * Implements hook_theme().
 */
function modularform_theme() {
  return [
    'dashboard' => [
      'variables' => [
        'header' => NULL,
        'rows' => NULL,
      ],
      'template' => 'modularform-dashboard',
      'path' => drupal_get_path('module', 'modularform') . '/templates',
    ],
    'modularform_initial_template' => [
      'render element' => 'form',
      'template' => 'modularform-initial',
      'path' => drupal_get_path('module', 'modularform') . '/templates',
    ],
  ];
}

