<?php

module_load_include('inc', 'modularform_analytics', 'includes/modularform_analytics.wordcloud');


/**
 * @file
 * modularform_analytics.module
 */

/**
 * Implements hook_menu_alter().
 * Tightens access on the analytics routes defined by modularform_analytics.
 */
function modularform_analytics_menu_alter(&$items) {
  $routes = ['modularform/analytics', 'modularform/analytics/wordcloud'];
  foreach ($routes as $path) {
    if (isset($items[$path])) {
      $items[$path]['access callback']  = '_modularform_analytics_access_real';
      $items[$path]['access arguments'] = [];
    }
  }
}



/**
 * Implements hook_permission().
 */
function modularform_analytics_permission() {
  return [
    'access modularform analytics' => [
      'title'       => t('Access Modularform Analytics'),
      'description' => t('View analytics pages including the tag word cloud.'),
    ],
  ];
}

/**
 * Access callback for all analytics routes.
 *
 * - site administrator: always.
 * - admin / analyst: yes if they hold 'view analytics' from the core module
 *   AND 'access modularform analytics' from this module.
 * - others: no.
 */
function _modularform_analytics_access_real() {
  if (_modularform_is_site_admin()) {
    return TRUE;
  }
  if (_modularform_is_form_admin()) {
    return user_access('view analytics')
      && user_access('access modularform analytics');
  }
  return FALSE;
}

/**
 * Implements hook_library().
 */
function modularform_analytics_library() {
  $path = drupal_get_path('module', 'modularform_analytics');

  return [
    'wordcloud' => [
      'title'   => 'Modularform Tag Word Cloud',
      'version' => '1.0',
      'js'      => [
        $path . '/js/d3.min.js'               => [],
        $path . '/js/d3.layout.cloud.js'      => [],
        $path . '/js/modularform_wordcloud.js' => [],
      ],
      'css' => [
        $path . '/css/modularform_wordcloud.css' => [],
      ],
      'dependencies' => [
        ['system', 'jquery'],
      ],
    ],
  ];
}
