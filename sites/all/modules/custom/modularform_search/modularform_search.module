<?php

module_load_include('inc', 'modularform_search', 'includes/modularform_forms_index');
module_load_include('inc', 'modularform_search', 'includes/modularform_response_index');


/**
 * @file modularform_search.module
 * Solr-powered search for Modularform.
 */


/**
 * Implements hook_apachesolr_index_entities_alter().
 *
 * Registers modularform_form as an entity type Apache Solr should index.
 * Without this, Solr ignores the entity entirely — the status/document/reindex
 * callbacks in modularform_search.forms.inc are never called.
 */
function modularform_search_apachesolr_entity_info_alter(&$entity_info) {
  //  forms entity_alter
  $entity_info['modularform_form']['indexable']        = TRUE;
  $entity_info['modularform_form']['index_table']      = 'apachesolr_index_entities';
  $entity_info['modularform_form']['status callback'][]  = 'modularform_search_form_status_callback';
  $entity_info['modularform_form']['document callback'][] = 'modularform_search_form_document_callback';
  $entity_info['modularform_form']['reindex callback'] = 'modularform_search_form_reindex_callback';

//  response entity_alter
  $entity_info['modularform_response']['indexable']         = TRUE;
  $entity_info['modularform_response']['index_table']       = 'apachesolr_index_entities';
  $entity_info['modularform_response']['status callback'][] = 'modularform_search_response_status_callback';
  $entity_info['modularform_response']['document callback'][] = 'modularform_search_response_document_callback';
  $entity_info['modularform_response']['reindex callback']  = 'modularform_search_response_reindex_callback';
}

/**
 * Queue a form for indexing or remove it if soft-deleted.
 * Called on insert and update.
 */
function modularform_search_solr_sync($entity, $entity_type) {
  if (!empty($entity->deleted_at)) {
    modularform_search_solr_remove($entity->id, $entity_type);
  }
  else {
    apachesolr_mark_entity($entity_type, $entity->id);
    modularform_search_solr_index_now($entity_type);
  }
}

/**
 * Remove a form from all Solr environments and the index queue.
 * Called on hard delete and soft delete.
 */
function modularform_search_solr_remove($entity_id, $entity_type) {
  foreach (apachesolr_load_all_environments() as $environment) {
    apachesolr_remove_entity($environment['env_id'], $entity_type, $entity_id);
  }
}

/**
 * Immediately trigger Solr indexing across all environments.
 * Bypasses cron by invoking the indexer directly.
 */
function modularform_search_solr_index_now() {
  try {
    $environment = apachesolr_default_environment();
    $env_id = is_array($environment) ? $environment['env_id'] : $environment;

    apachesolr_index_entities($env_id, 50);

    $solr = apachesolr_get_solr($env_id);
    $solr->commit();
  }
  catch (Exception $e) {
    watchdog(
      'modularform_search',
      'Solr immediate index failed: @msg',
      ['@msg' => $e->getMessage()],
      WATCHDOG_ERROR
    );
  }
}







