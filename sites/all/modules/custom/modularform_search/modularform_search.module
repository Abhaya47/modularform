<?php

module_load_include('inc', 'modularform_search', 'includes/modularform_search_forms');
module_load_include('inc', 'modularform_search', 'includes/modularform_response_index');


/**
 * @file modularform_search.module
 * Solr-powered search for Modularform.
 */


/**
 * Implements hook_apachesolr_index_entities_alter().
 *
 * Registers modularform_form as an entity type Apache Solr should index.
 * Without this, Solr ignores the entity entirely — the status/document/reindex
 * callbacks in modularform_search.forms.inc are never called.
 */
function modularform_search_apachesolr_entity_info_alter(&$entity_info) {
  //  forms entity_alter
  $entity_info['modularform_form']['indexable']        = TRUE;
  $entity_info['modularform_form']['index_table']      = 'apachesolr_index_entities';
  $entity_info['modularform_form']['status callback'][]  = 'modularform_search_form_status_callback';
  $entity_info['modularform_form']['document callback'][] = 'modularform_search_form_document_callback';
  $entity_info['modularform_form']['reindex callback'] = 'modularform_search_form_reindex_callback';

//  response entity_alter
  $entity_info['modularform_response']['indexable']         = TRUE;
  $entity_info['modularform_response']['index_table']       = 'modularform_response_solr_queue';
  $entity_info['modularform_response']['status callback'][] = 'modularform_search_response_status_callback';
  $entity_info['modularform_response']['document callback'][] = 'modularform_search_response_document_callback';
  $entity_info['modularform_response']['reindex callback']  = 'modularform_search_response_reindex_callback';
}









