<?php

/**
 * @file
 * Modularform Export module.
 *
 * Exposes batch CSV export for modularform forms.
 * UI and form selection live in the modularform dashboard.
 */

// ════════════════════════════════════════════════════════════════════════════
// MENU
// ════════════════════════════════════════════════════════════════════════════

function modularform_export_menu() {
  $items['modularform/export/page'] = [
    'title' => 'Export Forms',
    'page callback' => 'modularform_export_page',
    'page arguments' => [],
    'access callback' => 'user_is_logged_in',
    'type' => MENU_CALLBACK,
  ];

  $items['modularform/export/download/%'] = [
    'title' => 'Download Export',
    'page callback' => '_modularform_export_download',
    'page arguments' => [3],
    'access callback' => 'user_is_logged_in', // minimum — zip is scoped to the user anyway
    'type' => MENU_CALLBACK,
  ];

  return $items;
}

// ════════════════════════════════════════════════════════════════════════════
// THEME
// ════════════════════════════════════════════════════════════════════════════

/**
 * Implements hook_theme().
 */
function modularform_export_theme() {
  $module_path = drupal_get_path('module', 'modularform_export');
  return [
    'modularform_export_page' => [
      'variables' => [
        'records' => [],
        'token' => '',
        'fids_hidden' => '',
        'count' => 0,
      ],
      'template' => 'modularform-export-page',
      'path' => $module_path . '/templates',
    ],
  ];
}

// ════════════════════════════════════════════════════════════════════════════
// EXPORT PAGE
// ════════════════════════════════════════════════════════════════════════════

/**
 * Page callback: modularform/export/page?fids=1,2,3
 */
function modularform_export_page() {
  $raw = isset($_GET['fids']) ? $_GET['fids'] : '';
  $fids = _modularform_export_parse_fids($raw);

  if (empty($fids)) {
    drupal_set_message(t('No valid forms were selected for export.'), 'warning');
    drupal_goto('forms');
  }

  $records = _modularform_export_load_forms($fids);

  if (empty($records)) {
    drupal_set_message(t('None of the selected forms could be found.'), 'error');
    drupal_goto('forms');
  }

  // Handle POST — one of the two export buttons was clicked
  if ($_SERVER['REQUEST_METHOD'] === 'POST'
    && !empty($_POST['token'])
    && drupal_valid_token($_POST['token'], 'modularform_export_page')
  ) {
    $confirmed_fids = array_keys($records);

    if (!empty($_POST['op_forms'])) {
      modularform_export_start($confirmed_fids);
      batch_process('/forms/manage');
    }
    elseif (!empty($_POST['op_responses'])) {
      modularform_export_responses_start($confirmed_fids);
      batch_process('/forms/manage');
    }
  }

  drupal_set_title(t('Export forms'));

  $module_path = drupal_get_path('module', 'modularform_export');

  return [
    '#theme' => 'modularform_export_page',
    '#records' => $records,
    '#token' => drupal_get_token('modularform_export_page'),
    '#fids_hidden' => implode(',', array_keys($records)),
    '#count' => count($records),
    '#attached' => [
      'css' => [$module_path . '/css/export-page.css'],
    ],
  ];
}

// ════════════════════════════════════════════════════════════════════════════
// HELPERS
// ════════════════════════════════════════════════════════════════════════════

/**
 * Parses a comma-separated fids string into a clean array of ints.
 *
 * @param string $raw
 *
 * @return int[]
 */
function _modularform_export_parse_fids($raw) {
  if (empty($raw)) {
    return [];
  }
  $fids = [];
  foreach (explode(',', $raw) as $part) {
    $id = (int) trim($part);
    if ($id > 0) {
      $fids[] = $id;
    }
  }
  return array_unique($fids);
}

/**
 * Loads and validates form records for the given fids, keyed by id.
 *
 * @param int[] $fids
 *
 * @return object[]  Keyed by form id.
 */
function _modularform_export_load_forms(array $fids) {
  if (empty($fids)) {
    return [];
  }

  $result = db_select('modularform_forms', 'f')
    ->fields('f', ['id', 'title', 'status', 'created_at'])
    ->condition('f.id', $fids, 'IN')
    ->isNull('f.deleted_at')
    ->orderBy('f.title', 'ASC')
    ->execute();

  $records = [];
  foreach ($result as $row) {
    // Reuse your existing access check — same gate as viewing a form.
    if (form_view_access($row->id)) {
      $records[(int) $row->id] = $row;
    }
  }
  return $records;
}

// ════════════════════════════════════════════════════════════════════════════
// EXPORT INFRASTRUCTURE (unchanged)
// ════════════════════════════════════════════════════════════════════════════

/**
 * Implements hook_libraries_info().
 */
function modularform_export_libraries_info() {
  return [
    'openspout' => [
      'name' => 'OpenSpout',
      'version' => '4.x',
      'files' => ['php' => ['src/autoloader.php']],
    ],
  ];
}

/**
 * Loads the OpenSpout library.
 */
function modularform_export_load_openspout() {
  $autoload = DRUPAL_ROOT . '/sites/all/libraries/openspout/vendor/autoload.php';
  if (!file_exists($autoload)) {
    watchdog('modularform_export', 'OpenSpout autoloader not found.', [], WATCHDOG_ERROR);
    return FALSE;
  }
  require_once $autoload;
  return TRUE;
}

/**
 * Public entry point: export form definitions.
 *
 * @param int[] $fids
 */
const MODULARFORM_EXPORT_CHUNK_SIZE = 10;

function modularform_export_start(array $fids) {
  module_load_include('inc', 'modularform', 'includes/load_response_data');
  if (empty($fids)) {
    drupal_set_message(t('No forms selected for export.'), 'warning');
    return;
  }

  $operations = [];
  $chunks = array_chunk($fids, MODULARFORM_EXPORT_CHUNK_SIZE);
  foreach ($chunks as $chunk) {
    $operations[] = ['_modularform_export_process_chunk', [$chunk]];
  }
  $operations[] = ['_modularform_export_zip', []];

  batch_set([
    'title'            => t('Exporting forms'),
    'init_message'     => t('Preparing export...'),
    'progress_message' => t('Processed @current of @total chunks.'),
    'error_message'    => t('An error occurred during export.'),
    'finished'         => '_modularform_export_finished',
    'operations'       => $operations,
    'file'             => drupal_get_path('module', 'modularform_export') . '/includes/modularform_export.batch.inc',
  ]);
}

function modularform_export_responses_start(array $fids): void {
  module_load_include('inc', 'modularform', 'includes/load_response_data');
  if (empty($fids)) {
    drupal_set_message(t('No forms selected for export.'), 'warning');
    return;
  }

  $operations = [];
  $chunks = array_chunk($fids, MODULARFORM_EXPORT_CHUNK_SIZE);
  foreach ($chunks as $chunk) {
    $operations[] = ['_modularform_export_responses_process_chunk', [$chunk]];
  }
  $operations[] = ['_modularform_export_zip', []];

  batch_set([
    'title'            => t('Exporting form responses'),
    'init_message'     => t('Preparing export...'),
    'progress_message' => t('Processed @current of @total chunks.'),
    'error_message'    => t('An error occurred during export.'),
    'finished'         => '_modularform_export_finished',
    'operations'       => $operations,
    'file'             => drupal_get_path('module', 'modularform_export') . '/includes/modularform_export_responses.inc',
  ]);
}

/**
 * Batch operation: zip all exported CSVs.
 */
function _modularform_export_zip(&$context) {
  if (empty($context['results']['files'])) {
    $context['results']['errors'][] = t('No CSV files to zip.');
    return;
  }

  $timestamp = REQUEST_TIME;
  $zip_real_path = drupal_realpath('private://modularform_exports') . '/export_' . $timestamp . '.zip';

  $zip = new ZipArchive();
  if ($zip->open($zip_real_path, ZipArchive::CREATE) !== TRUE) {
    watchdog('modularform_export', 'Could not create zip file at @path.', ['@path' => $zip_real_path], WATCHDOG_ERROR);
    $context['results']['errors'][] = t('Could not create zip archive.');
    return;
  }

  foreach ($context['results']['files'] as $filepath) {
    if (file_exists($filepath)) {
      $zip->addFile($filepath, basename($filepath));
    }
  }
  $zip->close();

  foreach ($context['results']['files'] as $filepath) {
    file_unmanaged_delete($filepath);
  }

  $context['results']['zip'] = $zip_real_path;
  $context['message'] = t('Archive created successfully.');
}

/**
 * Batch finished callback.
 */
function _modularform_export_finished($success, $results, $operations) {
  if (!empty($results['errors'])) {
    foreach ($results['errors'] as $error) {
      drupal_set_message($error, 'error');
    }
  }

  if ($success && !empty($results['zip'])) {
    $filename = basename($results['zip']);
    variable_set('modularform_export_last_zip_' . $filename . '_' . $GLOBALS['user']->uid, $results['zip']);
    $url = url('modularform/export/download/' . $filename);
    drupal_set_message(t('Export complete. <a href="@url">Download your export</a>.', ['@url' => $url]));
  }
  else {
    drupal_set_message(t('Export failed or produced no output.'), 'error');
  }
}

/**
 * Implements hook_cron().
 */
function modularform_export_cron() {
  $real_dir = drupal_realpath('private://modularform_exports');
  if (!$real_dir || !is_dir($real_dir)) {
    return;
  }
  $expiry = REQUEST_TIME - 86400;
  foreach (new DirectoryIterator($real_dir) as $file) {
    if ($file->isDot() || $file->isDir()) {
      continue;
    }
    if ($file->getMTime() < $expiry) {
      file_unmanaged_delete($file->getPathname());
      watchdog('modularform_export', 'Deleted expired export file: @file', ['@file' => $file->getFilename()], WATCHDOG_INFO);
    }
  }
}

/**
 * Page callback: serve a zip file for download.
 */
function _modularform_export_download($filename) {
  global $user;
  $zip_path = variable_get('modularform_export_last_zip_' . $filename . '_' . $user->uid, NULL);

  if (!$zip_path || !file_exists($zip_path)) {
    drupal_not_found();
    return;
  }

  $uri = 'private://modularform_exports/' . $filename;
  file_transfer($uri, [
    'Content-Type'        => 'application/zip',
    'Content-Disposition' => 'attachment; filename="' . $filename . '"',
    'Content-Length'      => filesize($zip_path),
  ]);
}
